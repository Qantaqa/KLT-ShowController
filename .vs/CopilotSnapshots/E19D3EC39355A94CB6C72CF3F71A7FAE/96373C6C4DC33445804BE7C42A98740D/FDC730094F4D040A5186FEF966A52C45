    ' Nieuw: bereken en highlight de "volgende" groep in DG_Show
    ' =====================================================================

    ' Haalt de huidige actieve groep (waar btnApply=">") op
    Private Function TryGetCurrentActiveTriple(DG_Show As DataGridView, ByRef act As String, ByRef sceneId As Integer, ByRef eventId As Integer, ByRef activeIndex As Integer) As Boolean
        act = ""
        sceneId = -1
        eventId = -1
        activeIndex = -1

        For Each row As DataGridViewRow In DG_Show.Rows
            If row.IsNewRow Then Continue For
            If Convert.ToString(row.Cells("btnApply").Value) = ">" Then
                act = Convert.ToString(row.Cells("colAct").Value)
                Integer.TryParse(Convert.ToString(row.Cells("colSceneId").Value), sceneId)
                Integer.TryParse(Convert.ToString(row.Cells("colEventId").Value), eventId)
                activeIndex = row.Index
                Return True
            End If
        Next

        Return False
    End Function

    ' Bepaalt de volgende groep (eerst: volgend event in dezelfde scene; dan: volgende scene in dezelfde act; anders: eerste rij van volgende act)
    Private Function FindNextGroupFromCurrent(DG_Show As DataGridView, ByRef nextAct As String, ByRef nextSceneId As Integer, ByRef nextEventId As Integer) As Boolean
        nextAct = ""
        nextSceneId = -1
        nextEventId = -1

        Dim curAct As String = ""
        Dim curScene As Integer = -1
        Dim curEvent As Integer = -1
        Dim curIndex As Integer = -1

        If Not TryGetCurrentActiveTriple(DG_Show, curAct, curScene, curEvent, curIndex) Then
            Return False
        End If

        ' 1) Volgend event in dezelfde scene
        For Each row As DataGridViewRow In DG_Show.Rows
            If row.IsNewRow OrElse row.Index <= curIndex Then Continue For
            Dim act = Convert.ToString(row.Cells("colAct").Value)
            Dim sceneId = Convert.ToInt32(If(row.Cells("colSceneId").Value, 0))
            Dim eventId = Convert.ToInt32(If(row.Cells("colEventId").Value, 0))
            If act = curAct AndAlso sceneId = curScene AndAlso eventId > curEvent Then
                nextAct = act : nextSceneId = sceneId : nextEventId = eventId
                Return True
            End If
        Next

        ' 2) Volgende scene in dezelfde act (eerste rij van die scene)
        For Each row As DataGridViewRow In DG_Show.Rows
            If row.IsNewRow OrElse row.Index <= curIndex Then Continue For
            Dim act = Convert.ToString(row.Cells("colAct").Value)
            Dim sceneId = Convert.ToInt32(If(row.Cells("colSceneId").Value, 0))
            Dim eventId = Convert.ToInt32(If(row.Cells("colEventId").Value, 0))
            If act = curAct AndAlso sceneId > curScene Then
                nextAct = act : nextSceneId = sceneId : nextEventId = eventId
                Return True
            End If
        Next

        ' 3) Eerste rij na het verlaten van de huidige act (= volgende act)
        Dim leftCurrentAct As Boolean = False
        For Each row As DataGridViewRow In DG_Show.Rows
            If row.IsNewRow Then Continue For
            Dim act = Convert.ToString(row.Cells("colAct").Value)
            If row.Index <= curIndex Then Continue For
            If Not leftCurrentAct AndAlso act = curAct Then
                Continue For
            End If
            If Not leftCurrentAct AndAlso act <> curAct Then
                Dim sceneId = Convert.ToInt32(If(row.Cells("colSceneId").Value, 0))
                Dim eventId = Convert.ToInt32(If(row.Cells("colEventId").Value, 0))
                nextAct = act : nextSceneId = sceneId : nextEventId = eventId
                Return True
            End If
        Next

        Return False
    End Function

    ' Verwijdert alle groene highlight
    Private Sub ClearNextGroupHighlight(DG_Show As DataGridView)
        For Each row As DataGridViewRow In DG_Show.Rows
            If row.IsNewRow Then Continue For
            row.DefaultCellStyle.BackColor = DG_Show.DefaultCellStyle.BackColor
        Next
    End Sub

    ' Kleurt de rijen van de "volgende" groep lichtgroen, selectie van huidige groep blijft gewoon selectie
    Public Sub UpdateNextGroupHighlight(DG_Show As DataGridView)
        On Error Resume Next

        Dim nextAct As String = ""
        Dim nextScene As Integer = -1
        Dim nextEvent As Integer = -1

        Dim hasNext As Boolean = FindNextGroupFromCurrent(DG_Show, nextAct, nextScene, nextEvent)

        For Each row As DataGridViewRow In DG_Show.Rows
            If row.IsNewRow Then Continue For

            If hasNext Then
                Dim act = Convert.ToString(row.Cells("colAct").Value)
                Dim sceneId = Convert.ToInt32(If(row.Cells("colSceneId").Value, 0))
                Dim eventId = Convert.ToInt32(If(row.Cells("colEventId").Value, 0))

                If act = nextAct AndAlso sceneId = nextScene AndAlso eventId = nextEvent Then
                    row.DefaultCellStyle.BackColor = Color.Green
                Else
                    row.DefaultCellStyle.BackColor = DG_Show.DefaultCellStyle.BackColor
                End If
            Else
                row.DefaultCellStyle.BackColor = DG_Show.DefaultCellStyle.BackColor
            End If
        Next
    End Sub

    Public Sub Reselect_Rows(DG_Show As DataGridView)
        ' Reselect rows based on btnApply value and scroll the first selected row to top
        Dim firstSelectedIndex As Integer = -1

        For Each row As DataGridViewRow In DG_Show.Rows
            If row.IsNewRow Then
                row.Selected = False
                Continue For
            End If

            Dim btnVal As String = If(row.Cells("btnApply").Value IsNot Nothing, row.Cells("btnApply").Value.ToString(), "")
            If btnVal = ">" Then
                row.Selected = True
                If firstSelectedIndex = -1 AndAlso row.Visible Then
                    firstSelectedIndex = row.Index
                End If
            Else
                row.Selected = False
            End If
        Next

        ' Scroll so the first selected row is at the top of the grid (if possible)
        Try
            If firstSelectedIndex >= 0 Then
                ' Ensure the row is visible (may be filtered); if not, look for the next visible selected row
                If Not DG_Show.Rows(firstSelectedIndex).Visible Then
                    Dim found As Boolean = False
                    For i As Integer = firstSelectedIndex To DG_Show.Rows.Count - 1
                        If DG_Show.Rows(i).Visible AndAlso DG_Show.Rows(i).Selected Then
                            firstSelectedIndex = i
                            found = True
                            Exit For
                        End If
                    Next
                    If Not found Then
                        ' try searching earlier rows too
                        For i As Integer = firstSelectedIndex - 1 To 0 Step -1
                            If DG_Show.Rows(i).Visible AndAlso DG_Show.Rows(i).Selected Then
                                firstSelectedIndex = i
                                found = True
                                Exit For
                            End If
                        Next
                    End If
                End If

                If DG_Show.Rows.Count > 0 AndAlso firstSelectedIndex >= 0 AndAlso DG_Show.Rows(firstSelectedIndex).Visible Then
                    DG_Show.FirstDisplayedScrollingRowIndex = Math.Min(firstSelectedIndex, DG_Show.Rows.Count - 1)
                End If
            End If
        Catch ex As Exception
            ' Ignore errors (e.g., when setting FirstDisplayedScrollingRowIndex is invalid)
        End Try
    End Sub

    ' Populate dg_CurrentActions from the currently selected rows in DG_Show (only Type = Action)
    Public Sub UpdateCurrentActionsFromShow(DG_Show As DataGridView)
        On Error Resume Next
        If DG_Show Is Nothing Then Exit Sub
        Dim mainForm = TryCast(Application.OpenForms("FrmMain"), FrmMain)
        If mainForm Is Nothing Then Exit Sub
        If mainForm.dg_CurrentActions Is Nothing Then Exit Sub

        ' Clear current actions first
        mainForm.dg_CurrentActions.Rows.Clear()

        ' Iterate selected rows in DG_Show and add those with Type = Action
        For Each row As DataGridViewRow In DG_Show.Rows
            If row Is Nothing OrElse row.IsNewRow Then Continue For
            If Not row.Selected Then Continue For

            Dim colType = If(row.Cells("colType").Value IsNot Nothing, row.Cells("colType").Value.ToString(), "")
            If String.Equals(colType, "Action", StringComparison.OrdinalIgnoreCase) Then
                Dim timerVal = If(row.Cells("colTimer").Value IsNot Nothing, row.Cells("colTimer").Value.ToString(), "")
                Dim cueVal = If(row.Cells("colCue").Value IsNot Nothing, row.Cells("colCue").Value.ToString(), "")
                mainForm.dg_CurrentActions.Rows.Add(timerVal, cueVal)
            End If
        Next
    End Sub
End Module
