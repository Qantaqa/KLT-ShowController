Imports System.Runtime.InteropServices
Imports System.Windows.Forms

Public Class HotkeyControl
    Inherits NativeWindow
    Implements IDisposable

    Private Const WM_HOTKEY As Integer = &H312
    Private Const MOD_ALT As Integer = &H1
    Private Const MOD_CONTROL As Integer = &H2
    Private Const MOD_SHIFT As Integer = &H4

    Private ReadOnly _owner As Form
    Private ReadOnly _combo As ComboBox
    Private _disposed As Boolean

    Private Enum HotkeyId
        Output1 = 9001
        Output2 = 9002
        Output3 = 9003

        ' Extra hotkeys for main form buttons
        Start = 9010
        NextScene = 9011
        NextAct = 9012
        NextEvent = 9013
    End Enum

    Private Enum RemoteHotkeyId
        TopLeft = 9100
        TopCenter = 9101
        TopRight = 9102
        BottomLeft = 9103
        BottomCenter = 9104
        BottomRight = 9105
    End Enum

    <DllImport("user32.dll", SetLastError:=True)>
    Private Shared Function RegisterHotKey(hWnd As IntPtr, id As Integer, fsModifiers As Integer, vk As UInteger) As Boolean
    End Function

    <DllImport("user32.dll", SetLastError:=True)>
    Private Shared Function UnregisterHotKey(hWnd As IntPtr, id As Integer) As Boolean
    End Function

    Public Sub New(owner As Form, monitorCombo As ComboBox)
        _owner = owner
        _combo = monitorCombo

        AddHandler _owner.HandleCreated, AddressOf Owner_HandleCreated
        AddHandler _owner.HandleDestroyed, AddressOf Owner_HandleDestroyed

        If _owner.IsHandleCreated Then
            AssignHandle(_owner.Handle)
            RegisterOutputHotkeys()
        End If

        ' Initialize remote hotkeys after UI has been created
        If _owner.IsHandleCreated Then
            ' schedule to run on UI thread
            _owner.BeginInvoke(Sub()
                                   InitializeRemoteKeys()
                                   RegisterRemoteHotkeys()
                               End Sub)
        Else
            AddHandler _owner.Load, Sub(s, e)
                                        InitializeRemoteKeys()
                                        RegisterRemoteHotkeys()
                                    End Sub
        End If
    End Sub

    Private Sub Owner_HandleCreated(sender As Object, e As EventArgs)
        AssignHandle(_owner.Handle)
        RegisterOutputHotkeys()
    End Sub

    Private Sub Owner_HandleDestroyed(sender As Object, e As EventArgs)
        UnregisterOutputHotkeys()
        UnregisterRemoteHotkeys()
        ReleaseHandle()
    End Sub

    Public Sub RegisterOutputHotkeys()
        If Handle = IntPtr.Zero Then Return

        Dim ok As Boolean = True
        Dim success As Boolean

        ' Ctrl+Alt + 1/2/3
        success = RegisterHotKey(Handle, CInt(HotkeyId.Output1), MOD_CONTROL Or MOD_ALT, CUInt(Keys.D1))
        If Not success Then ReportHotkeyFailure("Ctrl+Alt+1")
        ok = ok And success

        success = RegisterHotKey(Handle, CInt(HotkeyId.Output2), MOD_CONTROL Or MOD_ALT, CUInt(Keys.D2))
        If Not success Then ReportHotkeyFailure("Ctrl+Alt+2")
        ok = ok And success

        success = RegisterHotKey(Handle, CInt(HotkeyId.Output3), MOD_CONTROL Or MOD_ALT, CUInt(Keys.D3))
        If Not success Then ReportHotkeyFailure("Ctrl+Alt+3")
        ok = ok And success

        ' Optional: NumPad 1/2/3
        success = RegisterHotKey(Handle, CInt(HotkeyId.Output1) + 100, MOD_CONTROL Or MOD_ALT, CUInt(Keys.NumPad1))
        If Not success Then ReportHotkeyFailure("Ctrl+Alt+NumPad1")
        ok = ok And success

        success = RegisterHotKey(Handle, CInt(HotkeyId.Output2) + 100, MOD_CONTROL Or MOD_ALT, CUInt(Keys.NumPad2))
        If Not success Then ReportHotkeyFailure("Ctrl+Alt+NumPad2")
        ok = ok And success

        success = RegisterHotKey(Handle, CInt(HotkeyId.Output3) + 100, MOD_CONTROL Or MOD_ALT, CUInt(Keys.NumPad3))
        If Not success Then ReportHotkeyFailure("Ctrl+Alt+NumPad3")
        ok = ok And success

        ' Register Ctrl+Alt+Shift + F1..F4 for main form buttons
        success = RegisterHotKey(Handle, CInt(HotkeyId.Start), MOD_CONTROL Or MOD_ALT Or MOD_SHIFT, CUInt(Keys.F1))       ' Ctrl+Alt+Shift+F1 -> btnControl_Start (was F9)
        If Not success Then ReportHotkeyFailure("Ctrl+Alt+Shift+F1")
        ok = ok And success

        success = RegisterHotKey(Handle, CInt(HotkeyId.NextScene), MOD_CONTROL Or MOD_ALT Or MOD_SHIFT, CUInt(Keys.F3))  ' Ctrl+Alt+Shift+F3 -> btnControl_NextScene (was F10)
        If Not success Then ReportHotkeyFailure("Ctrl+Alt+Shift+F3")
        ok = ok And success

        success = RegisterHotKey(Handle, CInt(HotkeyId.NextAct), MOD_CONTROL Or MOD_ALT Or MOD_SHIFT, CUInt(Keys.F4))    ' Ctrl+Alt+Shift+F4 -> btnControl_NextAct (was F11)
        If Not success Then ReportHotkeyFailure("Ctrl+Alt+Shift+F4")
        ok = ok And success

        success = RegisterHotKey(Handle, CInt(HotkeyId.NextEvent), MOD_CONTROL Or MOD_ALT Or MOD_SHIFT, CUInt(Keys.F2))  ' Ctrl+Alt+Shift+F2 -> btnControl_NextEvent (was F12)
        If Not success Then ReportHotkeyFailure("Ctrl+Alt+Shift+F2")
        ok = ok And success

        If Not ok Then
            ' Existing aggregate warning kept for backward compatibility; detailed messages are shown per-failure above.
            Try
                MessageBox.Show("One or more hotkeys failed to register. See individual messages for details.", "Hotkeys", MessageBoxButtons.OK, MessageBoxIcon.Warning)
            Catch
            End Try
        End If
    End Sub

    Private Sub ReportHotkeyFailure(keyName As String)
        Try
            Dim err As Integer = Marshal.GetLastWin32Error()
            MessageBox.Show(String.Format("Registering hotkey '{0}' failed (Win32 error {1}). It might be in use by another app.", keyName, err), "Hotkeys", MessageBoxButtons.OK, MessageBoxIcon.Warning)
        Catch
            ' Swallow any exceptions while reporting to avoid interfering with hotkey registration flow.
        End Try
    End Sub

    Private Sub UnregisterOutputHotkeys()
        If Handle = IntPtr.Zero Then Return

        UnregisterHotKey(Handle, CInt(HotkeyId.Output1))
        UnregisterHotKey(Handle, CInt(HotkeyId.Output2))
        UnregisterHotKey(Handle, CInt(HotkeyId.Output3))
        UnregisterHotKey(Handle, CInt(HotkeyId.Output1) + 100)
        UnregisterHotKey(Handle, CInt(HotkeyId.Output2) + 100)
        UnregisterHotKey(Handle, CInt(HotkeyId.Output3) + 100)

        ' Unregister function keys
        UnregisterHotKey(Handle, CInt(HotkeyId.Start))
        UnregisterHotKey(Handle, CInt(HotkeyId.NextScene))
        UnregisterHotKey(Handle, CInt(HotkeyId.NextAct))
        UnregisterHotKey(Handle, CInt(HotkeyId.NextEvent))
    End Sub

    Protected Overrides Sub WndProc(ByRef m As Message)
        If m.Msg = WM_HOTKEY Then
            Dim id As Integer = m.WParam.ToInt32()
            Select Case id
                Case CInt(HotkeyId.Output1), CInt(HotkeyId.Output1) + 100
                    SelectMonitorOutput(0) ' Output 1
                Case CInt(HotkeyId.Output2), CInt(HotkeyId.Output2) + 100
                    SelectMonitorOutput(1) ' Output 2
                Case CInt(HotkeyId.Output3), CInt(HotkeyId.Output3) + 100
                    SelectMonitorOutput(2) ' Output 3

                ' Main form button hotkeys
                Case CInt(HotkeyId.Start)
                    TriggerButtonClick("btnControl_Start")
                Case CInt(HotkeyId.NextScene)
                    TriggerButtonClick("btnControl_NextScene")
                Case CInt(HotkeyId.NextAct)
                    TriggerButtonClick("btnControl_NextAct")
                Case CInt(HotkeyId.NextEvent)
                    TriggerButtonClick("btnControl_NextEvent")

                ' Remote hotkeys
                Case CInt(RemoteHotkeyId.TopLeft)
                    HandleRemoteAction("TL")
                Case CInt(RemoteHotkeyId.TopCenter)
                    HandleRemoteAction("TC")
                Case CInt(RemoteHotkeyId.TopRight)
                    HandleRemoteAction("TR")
                Case CInt(RemoteHotkeyId.BottomLeft)
                    HandleRemoteAction("BL")
                Case CInt(RemoteHotkeyId.BottomCenter)
                    HandleRemoteAction("BC")
                Case CInt(RemoteHotkeyId.BottomRight)
                    HandleRemoteAction("BR")
            End Select
        End If
        MyBase.WndProc(m)
    End Sub

    Private Sub SelectMonitorOutput(index As Integer)
        If _combo Is Nothing OrElse _combo.IsDisposed Then Return

        If _combo.InvokeRequired Then
            _combo.BeginInvoke(Sub() SelectMonitorOutput(index))
            Return
        End If

        ' Eerst op index proberen
        If index >= 0 AndAlso index < _combo.Items.Count Then
            _combo.SelectedIndex = index
            Return
        End If

        ' Vallen terug naar tekst "Output 1/2/3"
        Dim targetText As String = "Output " & (index + 1).ToString()
        For i As Integer = 0 To _combo.Items.Count - 1
            Dim it = _combo.Items(i)
            If it IsNot Nothing AndAlso String.Equals(it.ToString(), targetText, StringComparison.OrdinalIgnoreCase) Then
                _combo.SelectedIndex = i
                Exit For
            End If
        Next
    End Sub

    ''' <summary>
    ''' Find the control by name on the main form and invoke its click action.
    ''' Uses BeginInvoke when required and will try PerformClick or call a PerformClick method via reflection.
    ''' </summary>
    Private Sub TriggerButtonClick(controlName As String)
        If _owner Is Nothing OrElse _owner.IsDisposed Then Return

        If _owner.InvokeRequired Then
            _owner.BeginInvoke(Sub() TriggerButtonClick(controlName))
            Return
        End If

        Try
            Dim matches() As Control = _owner.Controls.Find(controlName, True)
            If matches IsNot Nothing AndAlso matches.Length > 0 Then
                Dim ctrl As Control = matches(0)
                If TypeOf ctrl Is Button Then
                    DirectCast(ctrl, Button).PerformClick()
                Else
                    Dim mi = ctrl.GetType().GetMethod("PerformClick")
                    If mi IsNot Nothing Then
                        mi.Invoke(ctrl, Nothing)
                    End If
                End If
            End If
        Catch
            ' Swallow exceptions to avoid breaking hotkey handling
        End Try
    End Sub

    Private Sub HandleRemoteAction(slot As String)
        Try
            Dim actionName As String = ""
            Select Case slot
                Case "TL"
                    actionName = My.Settings.RemoteKeyTL_Action
                Case "TC"
                    actionName = My.Settings.RemoteKeyTC_Action
                Case "TR"
                    actionName = My.Settings.RemoteKeyTR_Action
                Case "BL"
                    actionName = My.Settings.RemoteKeyBL_Action
                Case "BC"
                    actionName = My.Settings.RemoteKeyBC_Action
                Case "BR"
                    actionName = My.Settings.RemoteKeyBR_Action
            End Select

            If String.IsNullOrWhiteSpace(actionName) Then Return
            actionName = actionName.ToUpperInvariant()

            Select Case actionName
                Case "START"
                    TriggerButtonClick("btnControl_Start")
                Case "NEXTACT"
                    TriggerButtonClick("btnControl_NextAct")
                Case "NEXTEVENT"
                    TriggerButtonClick("btnControl_NextEvent")
                Case "NEXTSCENE"
                    TriggerButtonClick("btnControl_NextScene")
                Case "SCRIPT_PGUP"
                    Dim main = TryCast(_owner, FrmMain)
                    If main IsNot Nothing Then
                        main.NavigatePdfToPage(Math.Max(1, main.currentPage - 1))
                    End If
                Case "SCRIPT_PGDOWN"
                    Dim main = TryCast(_owner, FrmMain)
                    If main IsNot Nothing Then
                        main.NavigatePdfToPage(main.currentPage + 1)
                    End If
            End Select
        Catch
            ' ignore
        End Try
    End Sub

    Protected Overridable Sub Dispose(disposing As Boolean)
        If Not _disposed Then
            If disposing Then
                ' managed
            End If
            Try
                UnregisterOutputHotkeys()
            Catch
            End Try
            Try
                UnregisterRemoteHotkeys()
            Catch
            End Try
            ReleaseHandle()
            If _owner IsNot Nothing Then
                RemoveHandler _owner.HandleCreated, AddressOf Owner_HandleCreated
                RemoveHandler _owner.HandleDestroyed, AddressOf Owner_HandleDestroyed
            End If
            _disposed = True
        End If
    End Sub

    Public Sub Dispose() Implements IDisposable.Dispose
        Dispose(True)
        GC.SuppressFinalize(Me)
    End Sub

    ' ---------------- Remote hotkeys registration & UI integration ----------------
    Private Sub InitializeRemoteKeys()
        ' Populate the textbox and combo controls from My.Settings and attach handlers
        Try
            PopulateControl("TBRK_TopLeft", My.Settings.RemoteKey_TL)
            PopulateControl("TBRK_TopCenter", My.Settings.RemoteKey_TC)
            PopulateControl("TBRK_TopRight", My.Settings.RemoteKey_TR)
            PopulateControl("TBRK_BottomLeft", My.Settings.RemoteKey_BL)
            PopulateControl("TBRK_BottomCenter", My.Settings.RemoteKey_BC)
            PopulateControl("TBRK_BottomRight", My.Settings.RemoteKey_BR)

            PopulateActionCombo("CBRK_TopLeft", My.Settings.RemoteKeyTL_Action)
            PopulateActionCombo("CBRK_TopCenter", My.Settings.RemoteKeyTC_Action)
            PopulateActionCombo("CBRK_TopRight", My.Settings.RemoteKeyTR_Action)
            PopulateActionCombo("CBRK_BottomLeft", My.Settings.RemoteKeyBL_Action)
            PopulateActionCombo("CBRK_BottomCenter", My.Settings.RemoteKeyBC_Action)
            PopulateActionCombo("CBRK_BottomRight", My.Settings.RemoteKeyBR_Action)
        Catch
        End Try
    End Sub

    Private Sub PopulateControl(ctrlName As String, value As String)
        Dim ctrl = FindControlByName(ctrlName)
        If ctrl Is Nothing Then Return
        If TypeOf ctrl Is TextBox Then
            Dim tb = DirectCast(ctrl, TextBox)
            tb.Text = If(value, "")
            tb.ReadOnly = False
            RemoveHandler tb.KeyDown, AddressOf RemoteKeyTextBox_KeyDown
            AddHandler tb.KeyDown, AddressOf RemoteKeyTextBox_KeyDown
            RemoveHandler tb.Click, AddressOf RemoteKeyTextBox_Click
            AddHandler tb.Click, AddressOf RemoteKeyTextBox_Click
        End If
    End Sub

    Private Sub PopulateActionCombo(ctrlName As String, selectedValue As String)
        Dim ctrl = FindControlByName(ctrlName)
        If ctrl Is Nothing Then Return
        If TypeOf ctrl Is ComboBox Then
            Dim cb = DirectCast(ctrl, ComboBox)
            cb.SelectedIndex = -1
            If Not String.IsNullOrWhiteSpace(selectedValue) Then
                For i = 0 To cb.Items.Count - 1
                    If String.Equals(cb.Items(i).ToString(), selectedValue, StringComparison.OrdinalIgnoreCase) Then
                        cb.SelectedIndex = i
                        Exit For
                    End If
                Next
            End If
            RemoveHandler cb.SelectedIndexChanged, AddressOf RemoteActionCombo_SelectedIndexChanged
            AddHandler cb.SelectedIndexChanged, AddressOf RemoteActionCombo_SelectedIndexChanged
        End If
    End Sub

    Private Function FindControlByName(name As String) As Control
        If _owner Is Nothing OrElse _owner.IsDisposed Then Return Nothing
        Dim matches() As Control = _owner.Controls.Find(name, True)
        If matches IsNot Nothing AndAlso matches.Length > 0 Then
            Return matches(0)
        End If
        Return Nothing
    End Function

    Private Sub RemoteKeyTextBox_Click(sender As Object, e As EventArgs)
        Try
            Dim tb = DirectCast(sender, TextBox)
            tb.Focus()
            tb.SelectAll()
            tb.Text = "Press desired key combination..."
        Catch
        End Try
    End Sub

    Private Sub RemoteKeyTextBox_KeyDown(sender As Object, e As KeyEventArgs)
        Try
            Dim tb = DirectCast(sender, TextBox)
            Dim parts As New List(Of String)()
            If e.Control Then parts.Add("CTRL")
            If e.Shift Then parts.Add("SHIFT")
            If e.Alt Then parts.Add("ALT")

            Dim keyName = e.KeyCode.ToString().ToUpperInvariant()
            ' Normalize PageUp/PageDown synonyms
            If keyName = "PRIOR" Then keyName = "PAGEUP"
            If keyName = "NEXT" Then keyName = "PAGEDOWN"

            ' Avoid capturing modifier-only presses
            If keyName = "CONTROLKEY" OrElse keyName = "SHIFTKEY" OrElse keyName = "MENU" Then
                Return
            End If

            parts.Add(keyName)
            Dim formatted = String.Join("+", parts)
            tb.Text = formatted

            ' Save to settings based on textbox name
            Select Case tb.Name.ToUpperInvariant()
                Case "TBRK_TOPLEFT"
                    My.Settings.RemoteKey_TL = formatted
                Case "TBRK_TOPCENTER"
                    My.Settings.RemoteKey_TC = formatted
                Case "TBRK_TOPRIGHT"
                    My.Settings.RemoteKey_TR = formatted
                Case "TBRK_BOTTOMLEFT"
                    My.Settings.RemoteKey_BL = formatted
                Case "TBRK_BOTTOMCENTER"
                    My.Settings.RemoteKey_BC = formatted
                Case "TBRK_BOTTOMRIGHT"
                    My.Settings.RemoteKey_BR = formatted
            End Select
            My.Settings.Save()

            ' Re-register remote hotkeys
            RegisterRemoteHotkeys()

            e.Handled = True
        Catch
        End Try
    End Sub

    Private Sub RemoteActionCombo_SelectedIndexChanged(sender As Object, e As EventArgs)
        Try
            Dim cb = DirectCast(sender, ComboBox)
            Dim sel = If(cb.SelectedItem IsNot Nothing, cb.SelectedItem.ToString(), "")
            Select Case cb.Name.ToUpperInvariant()
                Case "CBRK_TOPLEFT"
                    My.Settings.RemoteKeyTL_Action = sel
                Case "CBRK_TOPCENTER"
                    My.Settings.RemoteKeyTC_Action = sel
                Case "CBRK_TOPRIGHT"
                    My.Settings.RemoteKeyTR_Action = sel
                Case "CBRK_BOTTOMLEFT"
                    My.Settings.RemoteKeyBL_Action = sel
                Case "CBRK_BOTTOMCENTER"
                    My.Settings.RemoteKeyBC_Action = sel
                Case "CBRK_BOTTOMRIGHT"
                    My.Settings.RemoteKeyBR_Action = sel
            End Select
            My.Settings.Save()
        Catch
        End Try
    End Sub

    Private Sub RegisterRemoteHotkeys()
        If Handle = IntPtr.Zero Then Return
        ' First unregister existing
        UnregisterRemoteHotkeys()

        RegisterOneRemote("TBRK_TopLeft", CInt(RemoteHotkeyId.TopLeft), My.Settings.RemoteKey_TL)
        RegisterOneRemote("TBRK_TopCenter", CInt(RemoteHotkeyId.TopCenter), My.Settings.RemoteKey_TC)
        RegisterOneRemote("TBRK_TopRight", CInt(RemoteHotkeyId.TopRight), My.Settings.RemoteKey_TR)
        RegisterOneRemote("TBRK_BottomLeft", CInt(RemoteHotkeyId.BottomLeft), My.Settings.RemoteKey_BL)
        RegisterOneRemote("TBRK_BottomCenter", CInt(RemoteHotkeyId.BottomCenter), My.Settings.RemoteKey_BC)
        RegisterOneRemote("TBRK_BottomRight", CInt(RemoteHotkeyId.BottomRight), My.Settings.RemoteKey_BR)
    End Sub

    Private Sub UnregisterRemoteHotkeys()
        If Handle = IntPtr.Zero Then Return
        For id As Integer = CInt(RemoteHotkeyId.TopLeft) To CInt(RemoteHotkeyId.BottomRight)
            Try
                UnregisterHotKey(Handle, id)
            Catch
            End Try
        Next
    End Sub

    Private Sub RegisterOneRemote(controlName As String, id As Integer, hotkeyDef As String)
        If String.IsNullOrWhiteSpace(hotkeyDef) Then Return
        Try
            Dim t = ParseHotkeyString(hotkeyDef)
            Dim mods As Integer = 0
            Dim vk As UInteger = 0
            If t IsNot Nothing Then
                mods = t.Item1
                vk = t.Item2
            End If
            If vk = 0 Then Return
            Dim success = RegisterHotKey(Handle, id, mods, vk)
            If Not success Then ReportHotkeyFailure(hotkeyDef)
        Catch
        End Try
    End Sub

    Private Function ParseHotkeyString(hotkeyDef As String) As Tuple(Of Integer, UInteger)
        Dim mods As Integer = 0
        Dim vk As UInteger = 0
        If String.IsNullOrWhiteSpace(hotkeyDef) Then Return Tuple.Create(mods, vk)
        Try
            Dim parts = hotkeyDef.ToUpperInvariant().Split("+"c)
            For Each raw In parts
                Dim p = raw.Trim()
                If p = "" Then Continue For
                Select Case p
                    Case "CTRL", "CONTROL"
                        mods = mods Or MOD_CONTROL
                    Case "ALT"
                        mods = mods Or MOD_ALT
                    Case "SHIFT"
                        mods = mods Or MOD_SHIFT
                    Case Else
                        ' Try map common names to Keys
                        Dim keyToken = p
                        If keyToken = "PGUP" Then keyToken = "PAGEUP"
                        If keyToken = "PGDN" Then keyToken = "PAGEDOWN"
                        Try
                            Dim k As Keys = DirectCast([Enum].Parse(GetType(Keys), keyToken, True), Keys)
                            vk = CUInt(k)
                        Catch
                            ' ignore unknown
                        End Try
                End Select
            Next
        Catch
        End Try
        Return Tuple.Create(mods, vk)
    End Function

End Class