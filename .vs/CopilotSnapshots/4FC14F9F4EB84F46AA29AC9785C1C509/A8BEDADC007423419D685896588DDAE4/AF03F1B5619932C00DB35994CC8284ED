        ColorToHSV(currentColor, h, s, v)
        Dim newHue = hv / trkHue.Maximum * 360.0
        Dim col = ColorFromHSV(newHue, s, v)
        currentColor = Color.FromArgb(currentColor.A, col.R, col.G, col.B)
        UpdateAllControlsFromColor(currentColor)
    End Sub

