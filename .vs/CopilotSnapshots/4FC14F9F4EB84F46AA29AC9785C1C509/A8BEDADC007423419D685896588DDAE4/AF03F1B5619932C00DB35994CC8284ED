    Private Sub valueHTML_TextChanged(sender As Object, e As EventArgs) Handles valueHTML.TextChanged
        Dim t = valueHTML.Text.Trim()
        If String.IsNullOrEmpty(t) Then
            Return
        End If
        Try
            Dim c = ParseHexColor(t)
            UpdateAllControlsFromColor(c)
        Catch
            ' ignore parse errors silently for now
        End Try
    End Sub

