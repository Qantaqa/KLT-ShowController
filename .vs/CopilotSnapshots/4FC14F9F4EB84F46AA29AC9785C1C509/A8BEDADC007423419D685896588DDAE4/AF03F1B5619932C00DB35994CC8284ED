    Private Sub btnDefaultWindowColorSelector_Click(sender As Object, e As EventArgs) Handles btnDefaultWindowColorSelector.Click
        ' populate saved slots with system colors as a quick palette
        Dim sys = New Color() {SystemColors.Control, SystemColors.Window, SystemColors.Highlight, Color.Red, Color.Green, Color.Blue, Color.Yellow, Color.Magenta, Color.Cyan, Color.Black, Color.White}
        For i As Integer = 0 To savedSlots.Length - 1
            savedSlots(i).BackColor = sys(i Mod sys.Length)
        Next
    End Sub

    Private Sub pbColorWheel_MouseClick(sender As Object, e As MouseEventArgs) Handles pbColorWheel.MouseClick
        If pbColorWheel.Image Is Nothing Then
            Return
        End If
        Dim img = pbColorWheel.Image
        ' map click to image coordinates (SizeMode.StretchImage)
        Dim ix = CInt(e.X * img.Width / pbColorWheel.Width)
        Dim iy = CInt(e.Y * img.Height / pbColorWheel.Height)
        If ix < 0 Then
            ix = 0
        ElseIf ix >= img.Width Then
            ix = img.Width - 1
        End If
        If iy < 0 Then
            iy = 0
        ElseIf iy >= img.Height Then
            iy = img.Height - 1
        End If
        Try
            Dim bmp As Bitmap = CType(img, Bitmap)
            Dim picked As Color = bmp.GetPixel(ix, iy)
            ' use picked color RGB; maintain current alpha
            currentColor = Color.FromArgb(currentColor.A, picked.R, picked.G, picked.B)
            UpdateAllControlsFromColor(currentColor)
        Catch
            ' ignore if image is not a bitmap
        End Try
    End Sub

    Private Sub btnRestoreFromSlot_Click(sender As Object, e As EventArgs) Handles btnRestoreFromSlot.Click
        Dim index = CInt(valueSlot.Value) - 1
        If index >= 0 AndAlso index < savedSlots.Length Then
            Dim c = savedSlots(index).BackColor
            If Not c.IsEmpty Then
                UpdateAllControlsFromColor(c)
            End If
        End If
    End Sub

    Private Sub btnSaveToSlot_Click(sender As Object, e As EventArgs) Handles btnSaveToSlot.Click
        Dim index = CInt(valueSlot.Value) - 1
        If index >= 0 AndAlso index < savedSlots.Length Then
            savedSlots(index).BackColor = currentColor
            SaveSlotsToDisk() ' Save to disk after updating the slot
        End If
    End Sub

    Private Function GetSlotsFilePath() As String
        ' Use application directory and subdirectory for slots
        Dim appDir = Path.GetDirectoryName(Application.ExecutablePath)
        Dim slotsDir = Path.Combine(appDir, "ColorPickerSlots")
        If Not Directory.Exists(slotsDir) Then
            Directory.CreateDirectory(slotsDir)
        End If
        ' Use a fixed filename for slot data
        Return Path.Combine(slotsDir, "slots.dat")
    End Function

    Private Sub SaveSlotsToDisk()
        Dim path = GetSlotsFilePath()
        Using fs As New FileStream(path, FileMode.Create, FileAccess.Write)
            Using bw As New BinaryWriter(fs)
                For Each slot In savedSlots
                    Dim color = slot.BackColor
                    bw.Write(color.A)
                    bw.Write(color.R)
                    bw.Write(color.G)
                    bw.Write(color.B)
                Next
            End Using
        End Using
    End Sub

    Private Sub LoadSlotsFromDisk()
        Dim path = GetSlotsFilePath()
        If Not File.Exists(path) Then
            ' No slots file found, initialize to empty colors
            For Each slot In savedSlots
                slot.BackColor = Color.Empty
            Next
            Return
        End If
        Using fs As New FileStream(path, FileMode.Open, FileAccess.Read)
            Using br As New BinaryReader(fs)
                For Each slot In savedSlots
                    If fs.Position >= fs.Length Then Exit For
                    Dim a = br.ReadByte()
                    Dim r = br.ReadByte()
                    Dim g = br.ReadByte()
                    Dim b = br.ReadByte()
                    slot.BackColor = Color.FromArgb(a, r, g, b)
                Next
            End Using
        End Using
    End Sub

    ' Utility functions
    Private Function ColorToHex(c As Color) As String
        If c.A < 255 Then
            Return String.Format("#{0:X2}{1:X2}{2:X2}{3:X2}", c.A, c.R, c.G, c.B)
        Else
            Return String.Format("#{0:X2}{1:X2}{2:X2}", c.R, c.G, c.B)
        End If
    End Function

    Private Function ParseHexColor(text As String) As Color
        Dim t = text.Trim()
        If t.StartsWith("#") Then t = t.Substring(1)
        If t.Length = 6 Then
            Dim r = Convert.ToInt32(t.Substring(0, 2), 16)
            Dim g = Convert.ToInt32(t.Substring(2, 2), 16)
            Dim b = Convert.ToInt32(t.Substring(4, 2), 16)
            Return Color.FromArgb(255, r, g, b)
        ElseIf t.Length = 8 Then
            Dim a = Convert.ToInt32(t.Substring(0, 2), 16)
            Dim r = Convert.ToInt32(t.Substring(2, 2), 16)
            Dim g = Convert.ToInt32(t.Substring(4, 2), 16)
            Dim b = Convert.ToInt32(t.Substring(6, 2), 16)
            Return Color.FromArgb(a, r, g, b)
        Else
            Throw New FormatException("Invalid hex length")
        End If
    End Function

    ' HSV helpers (h in degrees 0-360, s & v in 0-1)
    Private Function ColorFromHSV(h As Double, s As Double, v As Double) As Color
        If s = 0 Then
            Dim val = CInt(Math.Round(v * 255))
            Return Color.FromArgb(val, val, val)
        End If
        Dim hh = h
        If hh >= 360 Then hh = 0
        hh = hh / 60.0
        Dim i = Math.Floor(hh)
        Dim ff = hh - i
        Dim p = v * (1 - s)
        Dim q = v * (1 - (s * ff))
        Dim t = v * (1 - (s * (1 - ff)))
        Dim r As Double, g As Double, b As Double
        Select Case CInt(i)
            Case 0
                r = v : g = t : b = p
            Case 1
                r = q : g = v : b = p
            Case 2
                r = p : g = v : b = t
            Case 3
                r = p : g = q : b = v
            Case 4
                r = t : g = p : b = v
            Case Else
                r = v : g = p : b = q
        End Select
        Return Color.FromArgb(CInt(Math.Round(r * 255)), CInt(Math.Round(g * 255)), CInt(Math.Round(b * 255)))
    End Function

    Private Sub ColorToHSV(c As Color, ByRef h As Double, ByRef s As Double, ByRef v As Double)
        Dim r = c.R / 255.0
        Dim g = c.G / 255.0
        Dim b = c.B / 255.0
        Dim max = Math.Max(r, Math.Max(g, b))
        Dim min = Math.Min(r, Math.Min(g, b))
        v = max
        Dim delta = max - min
        If max = 0 Then
            s = 0
            h = 0
            Return
        End If
        s = If(max = 0, 0, delta / max)
        If delta = 0 Then
            h = 0
            Return
        End If
        If r = max Then
            h = (g - b) / delta
        ElseIf g = max Then
            h = 2 + (b - r) / delta
        Else
            h = 4 + (r - g) / delta
        End If
        h = h * 60
        If h < 0 Then h += 360
    End Sub

