    Private Sub btnDefaultWindowColorSelector_Click(sender As Object, e As EventArgs) Handles btnDefaultWindowColorSelector.Click
        Try
            Using cd As New ColorDialog()
                cd.AllowFullOpen = True
                cd.AnyColor = True
                cd.FullOpen = True
                cd.Color = Color.FromArgb(currentColor.R, currentColor.G, currentColor.B)
                If cd.ShowDialog() = DialogResult.OK Then
                    ' apply selected color (keep current alpha)
                    Dim sel = Color.FromArgb(currentColor.A, cd.Color.R, cd.Color.G, cd.Color.B)
                    SelectedColor = sel

                    ' update label backgrounds to match overlay color
                    lbRGBValues.BackColor = Color.FromArgb(sel.A, sel.R, sel.G, sel.B)
                    lblHTMLValue.BackColor = Color.FromArgb(sel.A, sel.R, sel.G, sel.B)

                    pbColorArea.Invalidate()
                End If
            End Using
        Catch
            ' ignore errors from dialog
        End Try
    End Sub

