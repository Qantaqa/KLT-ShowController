        Try
            lbRGBValues.BackColor = col
            lblHTMLValue.BackColor = col
        Catch
        End Try
    End Sub

    Private Sub PopulateWledCombo()
        Try
            cbSelectedWLed.Items.Clear()
            Dim mainForm As FrmMain = TryCast(Application.OpenForms("FrmMain"), FrmMain)
            If mainForm Is Nothing Then Return

            For Each devRow As DataGridViewRow In mainForm.DG_Devices.Rows
                If devRow.IsNewRow Then Continue For
                Dim devName = Convert.ToString(devRow.Cells("colInstance").Value)
                If String.IsNullOrWhiteSpace(devName) Then Continue For

                Dim segmentsStr = Convert.ToString(devRow.Cells("colSegments").Value)
                If Not String.IsNullOrWhiteSpace(segmentsStr) Then
                    Dim matches = System.Text.RegularExpressions.Regex.Matches(segmentsStr, "\((\d+)-(\d+)\)")
                    Dim segIndex As Integer = 0
                    For Each m As System.Text.RegularExpressions.Match In matches
                        cbSelectedWLed.Items.Add(devName & "/" & segIndex.ToString())
                        segIndex += 1
                    Next
                Else
                    Dim segData = TryCast(devRow.Cells("colSegmentsData").Value, String)
                    If Not String.IsNullOrWhiteSpace(segData) Then
                        Try
                            Dim j = JArray.Parse(segData)
                            For i As Integer = 0 To j.Count - 1
                                cbSelectedWLed.Items.Add(devName & "/" & i.ToString())
                            Next
                        Catch
                            cbSelectedWLed.Items.Add(devName)
                        End Try
                    Else
                        cbSelectedWLed.Items.Add(devName)
                    End If
                End If
            Next

            If cbSelectedWLed.Items.Count > 0 Then cbSelectedWLed.SelectedIndex = 0
        Catch
        End Try
    End Sub

    Private Sub btnRestoreFromSlot_Click(sender As Object, e As EventArgs) Handles btnRestoreFromSlot.Click
        Dim index = CInt(valueSlot.Value) - 1
        If index < 0 OrElse index >= savedSlots.Length Then
            MessageBox.Show("Selecteer eerst een geldige slot (1-24).", "Selecteer slot", MessageBoxButtons.OK, MessageBoxIcon.Warning)
            Return
        End If
        Dim c = savedSlots(index).BackColor
        If Not c.IsEmpty Then
            UpdateAllControlsFromColor(c)
        Else
            MessageBox.Show("Geselecteerde slot is leeg.", "Lege slot", MessageBoxButtons.OK, MessageBoxIcon.Information)
        End If
    End Sub

    Private Sub btnSaveToSlot_Click(sender As Object, e As EventArgs) Handles btnSaveToSlot.Click
        Dim index = CInt(valueSlot.Value) - 1
        If index < 0 OrElse index >= savedSlots.Length Then
            MessageBox.Show("Selecteer eerst een geldige slot (1-24).", "Selecteer slot", MessageBoxButtons.OK, MessageBoxIcon.Warning)
            Return
        End If
        savedSlots(index).BackColor = currentColor
        SaveSlotsToDisk()
        MessageBox.Show("Kleur opgeslagen in slot " & (index + 1).ToString() & ".", "Opgeslagen", MessageBoxButtons.OK, MessageBoxIcon.Information)
    End Sub

    Private Async Sub btnRetrieveFromWLED_Click(sender As Object, e As EventArgs) Handles btnRetrieveFromWLED.Click
        Try
            Dim sel = Convert.ToString(cbSelectedWLed.SelectedItem)
            If String.IsNullOrWhiteSpace(sel) Then
                MessageBox.Show("Selecteer eerst een WLED apparaat/segment.", "Selecteer WLED", MessageBoxButtons.OK, MessageBoxIcon.Warning)
                Return
            End If

            Dim parts = sel.Split("/"c)
            Dim deviceName = parts(0)
            Dim segIndex As Integer = -1
            If parts.Length >= 2 Then Integer.TryParse(parts(1), segIndex)

            Dim mainForm As FrmMain = TryCast(Application.OpenForms("FrmMain"), FrmMain)
            If mainForm Is Nothing Then Return

            Dim devRow As DataGridViewRow = Nothing
            For Each row As DataGridViewRow In mainForm.DG_Devices.Rows
                If row.IsNewRow Then Continue For
                If String.Equals(Convert.ToString(row.Cells("colInstance").Value), deviceName, StringComparison.OrdinalIgnoreCase) Then
                    devRow = row
                    Exit For
                End If
            Next
            If devRow Is Nothing Then
                MessageBox.Show("Device niet gevonden in devices lijst.", "Fout", MessageBoxButtons.OK, MessageBoxIcon.Error)
                Return
            End If

            Dim ip = Convert.ToString(devRow.Cells("colIPAddress").Value)
            If String.IsNullOrWhiteSpace(ip) Then
                MessageBox.Show("Geen IP-adres gevonden voor geselecteerd device.", "Fout", MessageBoxButtons.OK, MessageBoxIcon.Error)
                Return
            End If

            Using client As New Net.Http.HttpClient()
                client.Timeout = TimeSpan.FromSeconds(3)
                Dim resp = Await client.GetAsync("http://" & ip & "/json")
                If Not resp.IsSuccessStatusCode Then
                    MessageBox.Show("Kon status van WLED niet ophalen: HTTP " & resp.StatusCode.ToString(), "Fout", MessageBoxButtons.OK, MessageBoxIcon.Error)
                    Return
                End If
                Dim json = Await resp.Content.ReadAsStringAsync()
                Dim jObj = JObject.Parse(json)
                Dim segArray = jObj.SelectToken("state.seg")
                If segArray Is Nothing Then
                    MessageBox.Show("Geen segmentgegevens gevonden in WLED response.", "Fout", MessageBoxButtons.OK, MessageBoxIcon.Error)
                    Return
                End If

                Dim targetSeg As JToken = Nothing
                If segIndex >= 0 Then
                    For Each s As JToken In segArray
                        Dim idToken = s.SelectToken("id")
                        If idToken IsNot Nothing AndAlso idToken.Type = JTokenType.Integer AndAlso CInt(idToken) = segIndex Then
                            targetSeg = s
                            Exit For
                        End If
                    Next
                    If targetSeg Is Nothing AndAlso segIndex < segArray.Count Then
                        targetSeg = segArray(segIndex)
                    End If
                Else
                    targetSeg = segArray.First
                End If

                If targetSeg Is Nothing Then
                    MessageBox.Show("Geselecteerde segment niet gevonden.", "Fout", MessageBoxButtons.OK, MessageBoxIcon.Error)
                    Return
                End If

                Dim colToken = targetSeg.SelectToken("col")
                If colToken Is Nothing OrElse Not colToken.HasValues Then
                    MessageBox.Show("Geen kleurarray gevonden voor het geselecteerde segment.", "Fout", MessageBoxButtons.OK, MessageBoxIcon.Error)
                    Return
                End If

                Dim firstColorToken = colToken.First
                Dim r As Integer = 0, g As Integer = 0, b As Integer = 0
                If firstColorToken.Type = JTokenType.Array Then
                    If firstColorToken.HasValues Then
                        r = CInt(firstColorToken(0))
                        g = CInt(firstColorToken(1))
                        b = CInt(firstColorToken(2))
                    End If
                ElseIf firstColorToken.Type = JTokenType.Integer Then
                    r = CInt(colToken(0))
                    g = CInt(colToken(1))
                    b = CInt(colToken(2))
                End If

                Dim c As Color = Color.FromArgb(255, r, g, b)
                SelectedColor = c
            End Using

        Catch ex As Exception
            MessageBox.Show("Fout bij ophalen kleur van WLED: " & ex.Message, "Fout", MessageBoxButtons.OK, MessageBoxIcon.Error)
        End Try
    End Sub

    Private Sub LoadSlotsFromDisk()
        Dim path = GetSlotsFilePath()
        If Not File.Exists(path) Then
            For Each slot In savedSlots
                slot.BackColor = Color.Empty
            Next
            Return
        End If
        Using fs As New FileStream(path, FileMode.Open, FileAccess.Read)
            Using br As New BinaryReader(fs)
                For Each slot In savedSlots
                    If fs.Position >= fs.Length Then Exit For
                    Dim a = br.ReadByte()
                    Dim r = br.ReadByte()
                    Dim g = br.ReadByte()
                    Dim b = br.ReadByte()
                    slot.BackColor = Color.FromArgb(a, r, g, b)
                Next
            End Using
        End Using
    End Sub

    Private Sub SaveSlotsToDisk()
        Dim path = GetSlotsFilePath()
        Using fs As New FileStream(path, FileMode.Create, FileAccess.Write)
            Using bw As New BinaryWriter(fs)
                For Each slot In savedSlots
                    Dim color = slot.BackColor
                    bw.Write(color.A)
                    bw.Write(color.R)
                    bw.Write(color.G)
                    bw.Write(color.B)
                Next
            End Using
        End Using
    End Sub

    Private Function GetSlotsFilePath() As String
        Dim appDir = Path.GetDirectoryName(Application.ExecutablePath)
        Dim slotsDir = Path.Combine(appDir, "ColorPickerSlots")
        If Not Directory.Exists(slotsDir) Then Directory.CreateDirectory(slotsDir)
        Return Path.Combine(slotsDir, "slots.dat")
    End Function

    ' Utility functions
    Private Function ColorToHex(c As Color) As String
        If c.A < 255 Then
            Return String.Format("#{0:X2}{1:X2}{2:X2}{3:X2}", c.A, c.R, c.G, c.B)
        Else
            Return String.Format("#{0:X2}{1:X2}{2:X2}", c.R, c.G, c.B)
        End If
    End Function

    Private Function ParseHexColor(text As String) As Color
        Dim t = text.Trim()
        If t.StartsWith("#") Then t = t.Substring(1)
        If t.Length = 6 Then
            Dim r = Convert.ToInt32(t.Substring(0, 2), 16)
            Dim g = Convert.ToInt32(t.Substring(2, 2), 16)
            Dim b = Convert.ToInt32(t.Substring(4, 2), 16)
            Return Color.FromArgb(255, r, g, b)
        ElseIf t.Length = 8 Then
            Dim a = Convert.ToInt32(t.Substring(0, 2), 16)
            Dim r = Convert.ToInt32(t.Substring(2, 2), 16)
            Dim g = Convert.ToInt32(t.Substring(4, 2), 16)
            Dim b = Convert.ToInt32(t.Substring(6, 2), 16)
            Return Color.FromArgb(a, r, g, b)
        Else
            Throw New FormatException("Invalid hex length")
        End If
    End Function

    Private Function ColorFromHSV(h As Double, s As Double, v As Double) As Color
        If s = 0 Then
            Dim val = CInt(Math.Round(v * 255))
            Return Color.FromArgb(val, val, val)
        End If
        Dim hh = h
        If hh >= 360 Then hh = 0
        hh = hh / 60.0
        Dim i = Math.Floor(hh)
        Dim ff = hh - i
        Dim p = v * (1 - s)
        Dim q = v * (1 - (s * ff))
        Dim t = v * (1 - (s * (1 - ff)))
        Dim r As Double, g As Double, b As Double
        Select Case CInt(i)
            Case 0
                r = v : g = t : b = p
            Case 1
                r = q : g = v : b = p
            Case 2
                r = p : g = v : b = t
            Case 3
                r = p : g = q : b = v
            Case 4
                r = t : g = p : b = v
            Case Else
                r = v : g = p : b = q
        End Select
        Return Color.FromArgb(CInt(Math.Round(r * 255)), CInt(Math.Round(g * 255)), CInt(Math.Round(b * 255)))
    End Function

    Private Sub ColorToHSV(c As Color, ByRef h As Double, ByRef s As Double, ByRef v As Double)
        Dim r = c.R / 255.0
        Dim g = c.G / 255.0
        Dim b = c.B / 255.0
        Dim max = Math.Max(r, Math.Max(g, b))
        Dim min = Math.Min(r, Math.Min(g, b))
        v = max
        Dim delta = max - min
        If max = 0 Then
            s = 0
            h = 0
            Return
        End If
        s = If(max = 0, 0, delta / max)
        If delta = 0 Then
            h = 0
            Return
        End If
        If r = max Then
            h = (g - b) / delta
        ElseIf g = max Then
            h = 2 + (b - r) / delta
        Else
            h = 4 + (r - g) / delta
        End If
        h = h * 60
        If h < 0 Then h += 360
    End Sub

