Partial Public Class ColorPickerExtented
    Public Sub New()
        InitializeComponent()
    End Sub

    Public Property SelectedColor As Color
        Get
            Return currentColor
        End Get
        Set(value As Color)
            currentColor = value
            UpdateAllControlsFromColor(currentColor)
        End Set
    End Property

    Private currentColor As Color = Color.FromArgb(255, 0, 0, 0)
    Private savedSlots As PictureBox()
    Private isMouseDownOnArea As Boolean = False

    Private Sub ColorPickerExtented_Load(sender As Object, e As EventArgs) Handles MyBase.Load
        ' initialize slots array in same order as designer
        savedSlots = New PictureBox() {slot_01, slot_02, slot_03, slot_04, slot_05, slot_06, slot_07, slot_08, slot_09, slot_10,
                                      slot_11, slot_12, slot_13, slot_14, slot_15, slot_16, slot_17, slot_18, slot_19, slot_20,
                                      slot_21, slot_22, slot_23, slot_24}

        ' initialize controls with currentColor
        UpdateAllControlsFromColor(currentColor)

        ' set sensible trackbar ranges
        trkRed.Minimum = 0 : trkRed.Maximum = 255
        trkGreen.Minimum = 0 : trkGreen.Maximum = 255
        trkBlue.Minimum = 0 : trkBlue.Maximum = 255
        trkAlpha.Minimum = 0 : trkAlpha.Maximum = 255
        trkHue.Minimum = 0 : trkHue.Maximum = 255

        ' ensure numeric controls match ranges
        valueRed.Minimum = 0 : valueRed.Maximum = 255
        valueGreen.Minimum = 0 : valueGreen.Maximum = 255
        ValueBlue.Minimum = 0 : ValueBlue.Maximum = 255
        valueAlpha.Minimum = 0 : valueAlpha.Maximum = 255
        ValueHue.Minimum = 0 : ValueHue.Maximum = 255

        ' numeric slot bounds
        valueSlot.Minimum = 1
        valueSlot.Maximum = savedSlots.Length

        ' load saved slots from disk
        LoadSlotsFromDisk()

        ' populate device/segment combo
        PopulateWledCombo()
    End Sub

    Private Sub UpdateAllControlsFromColor(c As Color)
        currentColor = c
        If trkRed.Value <> c.R Then trkRed.Value = c.R
        If trkGreen.Value <> c.G Then trkGreen.Value = c.G
        If trkBlue.Value <> c.B Then trkBlue.Value = c.B
        If trkAlpha.Value <> c.A Then trkAlpha.Value = c.A

        If valueRed.Value <> c.R Then valueRed.Value = c.R
        If valueGreen.Value <> c.G Then valueGreen.Value = c.G
        If ValueBlue.Value <> c.B Then ValueBlue.Value = c.B
        If valueAlpha.Value <> c.A Then valueAlpha.Value = c.A

        ' Hue mapping: convert RGB -> HSV and map H(0-360) to trackbar 0-255
        Dim h As Double, s As Double, v As Double
        ColorToHSV(c, h, s, v)
        Dim hueValue As Integer = CInt(Math.Round(h / 360.0 * trkHue.Maximum))
        If ValueHue.Value <> hueValue Then ValueHue.Value = hueValue
        If trkHue.Value <> hueValue Then trkHue.Value = hueValue

        valueHTML.Text = ColorToHex(c)
        lblHTMLValue.Text = valueHTML.Text
        lbRGBValues.Text = String.Format("R: {0:D3}  G: {1:D3}  B: {2:D3}", c.R, c.G, c.B)

        pbColorArea.Invalidate()

        ' Update label backgrounds whenever color changes
        UpdateLabelBackgrounds(c)
    End Sub

    Private Sub SetColorFromRGB(r As Integer, g As Integer, b As Integer, Optional a As Integer = 255)
        Dim c As Color = Color.FromArgb(a, r, g, b)
        UpdateAllControlsFromColor(c)
    End Sub

    Private Sub SetColorFromHSV(hueTrackValue As Integer, saturation As Double, value As Double, Optional alpha As Integer = 255)
        Dim h As Double = hueTrackValue / trkHue.Maximum * 360.0
        Dim c = ColorFromHSV(h, saturation, value)
        c = Color.FromArgb(alpha, c.R, c.G, c.B)
        UpdateAllControlsFromColor(c)
    End Sub

    Private Sub pbColorArea_MouseDown(sender As Object, e As MouseEventArgs) Handles pbColorArea.MouseDown
        isMouseDownOnArea = True
        HandleColorAreaMouse(e)
    End Sub

    Private Sub pbColorArea_MouseMove(sender As Object, e As MouseEventArgs) Handles pbColorArea.MouseMove
        If isMouseDownOnArea Then HandleColorAreaMouse(e)
    End Sub

    Private Sub pbColorArea_MouseUp(sender As Object, e As MouseEventArgs) Handles pbColorArea.MouseUp
        isMouseDownOnArea = False
    End Sub

    Private Sub HandleColorAreaMouse(e As MouseEventArgs)
        ' For this implementation, pbColorArea controls alpha when clicked horizontally
        If pbColorArea.Width <= 0 Then
            Return
        End If
        Dim ratio As Double = e.X / pbColorArea.Width
        ratio = Math.Max(0, Math.Min(1, ratio))
        Dim newA As Integer = CInt(Math.Round(ratio * 255))
        currentColor = Color.FromArgb(newA, currentColor.R, currentColor.G, currentColor.B)
        UpdateAllControlsFromColor(currentColor)
    End Sub

    Private Sub pbColorArea_Paint(sender As Object, e As PaintEventArgs) Handles pbColorArea.Paint
        Dim g = e.Graphics
        Dim w = pbColorArea.Width
        Dim h = pbColorArea.Height

        ' draw checkerboard
        Dim checkerSize = 8
        Using b1 As New SolidBrush(Color.FromArgb(220, 220, 220))
            Using b2 As New SolidBrush(Color.FromArgb(180, 180, 180))
                For y As Integer = 0 To h - 1 Step checkerSize
                    For x As Integer = 0 To w - 1 Step checkerSize
                        Dim use = ((x / checkerSize) + (y / checkerSize)) Mod 2
                        If use = 0 Then g.FillRectangle(b1, x, y, checkerSize, checkerSize) Else g.FillRectangle(b2, x, y, checkerSize, checkerSize)
                    Next
                Next
            End Using
        End Using

        ' overlay current color with alpha
        Using brush As New SolidBrush(Color.FromArgb(currentColor.A, currentColor.R, currentColor.G, currentColor.B))
            g.FillRectangle(brush, 0, 0, w, h)
        End Using

        ' draw border and text info
        Using pen As New Pen(Color.Black)
            g.DrawRectangle(pen, 0, 0, w - 1, h - 1)
        End Using

        Dim info = String.Format("A: {0} ({1:P0})", currentColor.A, currentColor.A / 255.0)
        Using sf As New StringFormat()
            sf.Alignment = StringAlignment.Near
            sf.LineAlignment = StringAlignment.Near
            g.DrawString(info, Me.Font, Brushes.Black, New PointF(4, 4), sf)
        End Using
    End Sub

