Imports System.Windows.Forms
Imports System.Drawing

Public Partial Class ColorPickerExtented
    Inherits Form

    Public Property SelectedColor As Color = Color.White
    Private Shared SavedColors(5) As Color? ' 6 slots, runtime buffer

    ' Controls are declared in the Designer partial class.

    Public Sub New()
        ' Parameterless constructor for Designer and default usage
        InitializeComponent()
        ApplyColorToControls(SelectedColor)
    End Sub

    Public Sub New(initial As Color)
        Me.SelectedColor = initial
        InitializeComponent()
        ApplyColorToControls(initial)
    End Sub

    Private Sub ApplyColorToControls(c As Color)
        If tbR IsNot Nothing Then tbR.Value = c.R
        If tbG IsNot Nothing Then tbG.Value = c.G
        If tbB IsNot Nothing Then tbB.Value = c.B
        If nudR IsNot Nothing Then nudR.Value = c.R
        If nudG IsNot Nothing Then nudG.Value = c.G
        If nudB IsNot Nothing Then nudB.Value = c.B
        UpdatePreview()
    End Sub

    Private Sub TrackBar_Scroll(sender As Object, e As EventArgs)
        If nudR IsNot Nothing Then nudR.Value = tbR.Value
        If nudG IsNot Nothing Then nudG.Value = tbG.Value
        If nudB IsNot Nothing Then nudB.Value = tbB.Value
        UpdateSelectedColorFromRGB()
    End Sub

    Private Sub Nud_ValueChanged(sender As Object, e As EventArgs)
        If tbR IsNot Nothing Then tbR.Value = CInt(nudR.Value)
        If tbG IsNot Nothing Then tbG.Value = CInt(nudG.Value)
        If tbB IsNot Nothing Then tbB.Value = CInt(nudB.Value)
        UpdateSelectedColorFromRGB()
    End Sub

    Private Sub UpdateSelectedColorFromRGB()
        Try
            SelectedColor = Color.FromArgb(CInt(nudR.Value), CInt(nudG.Value), CInt(nudB.Value))
        Catch ex As Exception
            ' ignore invalid values
        End Try
        UpdatePreview()
    End Sub

    Private Sub UpdatePreview()
        If pbPreview Is Nothing Then Return

        If pbPreview.Image IsNot Nothing Then
            Dim bmp = pbPreview.Image
            pbPreview.Image = Nothing
            bmp.Dispose()
        End If
        Dim bmpNew As New Bitmap(Math.Max(1, pbPreview.Width), Math.Max(1, pbPreview.Height))
        Using g = Graphics.FromImage(bmpNew)
            g.Clear(SelectedColor)
            Dim txt As String = String.Format("#{0:X2}{1:X2}{2:X2}", SelectedColor.R, SelectedColor.G, SelectedColor.B)
            Using f As New Font("Segoe UI", 9)
                Dim foreBrush = If((SelectedColor.R * 0.299 + SelectedColor.G * 0.587 + SelectedColor.B * 0.114) > 186, Brushes.Black, Brushes.White)
                g.DrawString(txt, f, foreBrush, New PointF(4, 4))
                g.DrawString($"R:{SelectedColor.R} G:{SelectedColor.G} B:{SelectedColor.B}", f, foreBrush, New PointF(4, 22))
            End Using
        End Using
        pbPreview.Image = bmpNew
        ' Update saved buttons color
        If flowSaved IsNot Nothing Then
            For Each ctrl As Control In flowSaved.Controls
                Dim b As Button = TryCast(ctrl, Button)
                If b IsNot Nothing Then
                    Dim idx = CInt(b.Tag)
                    b.BackColor = If(SavedColors(idx).HasValue, SavedColors(idx).Value, Color.Gray)
                End If
            Next
        End If
    End Sub

    Private Sub BtnStandard_Click(sender As Object, e As EventArgs)
        Using dlg As New ColorDialog()
            dlg.Color = SelectedColor
            If dlg.ShowDialog() = DialogResult.OK Then
                ApplyColorToControls(dlg.Color)
            End If
        End Using
    End Sub

    Private Sub SavedColor_Click(sender As Object, e As EventArgs)
        Dim b As Button = TryCast(sender, Button)
        If b Is Nothing Then Return
        Dim idx As Integer = CInt(b.Tag)
        If SavedColors(idx).HasValue Then
            ApplyColorToControls(SavedColors(idx).Value)
        Else
            ' Empty slot -> save current color
            SavedColors(idx) = SelectedColor
            UpdatePreview()
        End If
    End Sub

    Private Sub BtnSaveSlot_Click(sender As Object, e As EventArgs)
        Dim slot = CInt(nudSlot.Value) - 1
        If slot >= 0 AndAlso slot < SavedColors.Length Then
            SavedColors(slot) = SelectedColor
            UpdatePreview()
        End If
    End Sub

    Private Sub BtnClearSlot_Click(sender As Object, e As EventArgs)
        Dim slot = CInt(nudSlot.Value) - 1
        If slot >= 0 AndAlso slot < SavedColors.Length Then
            SavedColors(slot) = Nothing
            UpdatePreview()
        End If
    End Sub

    Private Sub BtnOk_Click(sender As Object, e As EventArgs)
        Me.DialogResult = DialogResult.OK
        Me.Close()
    End Sub
End Class