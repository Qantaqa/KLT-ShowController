    Public Sub InitializeScriptEditor()
        If isInitialized Then Return
        If FrmMain IsNot Nothing Then
            For Each tsi In FrmMain.ToolStrip_ScriptEditor.Items
                Dim dd = TryCast(tsi, ToolStripDropDownButton)
                If dd IsNot Nothing Then
                    For Each mi As ToolStripItem In dd.DropDownItems
                        Select Case mi.Text.ToLowerInvariant()
                            Case "import" : AddHandler mi.Click, AddressOf OnImportScriptClick
                            Case "load" : AddHandler mi.Click, AddressOf OnLoadScriptClick
                            Case "save" : AddHandler mi.Click, AddressOf OnSaveScriptClick
                        End Select
                    Next
                End If
                Dim btn = TryCast(tsi, ToolStripButton)
                If btn IsNot Nothing Then
                    Select Case btn.Name
                        Case "TSB_Editor_H1" : AddHandler btn.Click, Sub() ApplyHeader(1)
                        Case "TSB_Editor_H2" : AddHandler btn.Click, Sub() ApplyHeader(2)
                        Case "TSB_Editor_H3" : AddHandler btn.Click, Sub() ApplyHeader(3)
                        Case "TSB_Editor_Comment" : AddHandler btn.Click, AddressOf ApplyComment
                        Case "TSB_Editor_SongText" : AddHandler btn.Click, AddressOf ApplySongText
                        Case "TSB_Editor_SongTitle" : AddHandler btn.Click, AddressOf ApplySongTitle
                        Case "TSB_Editor_Acting" : AddHandler btn.Click, AddressOf ApplyActing
                        Case "TSB_Editor_Actor" : AddHandler btn.Click, AddressOf ApplyActor
                        Case "TSB_Editor_Bookmark" : AddHandler btn.Click, AddressOf ApplyBookmark
                    End Select
                End If
            Next
            AddHandler FrmMain.RichTextBox_ScriptEditor.TextChanged, AddressOf OnScriptTextChanged
        End If
        isInitialized = True
    End Sub

    Private Sub OnScriptTextChanged(sender As Object, e As EventArgs)
        SyncMetaWithCurrentLines()
    End Sub

    Private Sub SyncMetaWithCurrentLines()
        Dim lines = SplitIntoLines(FrmMain.RichTextBox_ScriptEditor.Text)
        ' Remove metadata for lines that no longer exist
        Dim keysToRemove = LineTypes.Keys.Where(Function(k) k >= lines.Length).ToList()
        For Each k In keysToRemove
            LineTypes.Remove(k)
        Next
        keysToRemove = BookmarkIds.Keys.Where(Function(k) k >= lines.Length).ToList()
        For Each k In keysToRemove
            BookmarkIds.Remove(k)
        Next
    End Sub

    Private Function SplitIntoLines(text As String) As String()
        If String.IsNullOrEmpty(text) Then Return Array.Empty(Of String)()
        Dim normalized = text.Replace(vbCrLf, vbLf).Replace(vbCr, vbLf)
        Dim parts = normalized.Split(New Char() {ControlChars.Lf}, StringSplitOptions.None)
        Return parts
    End Function

    ' ---------------- PDF IMPORT ----------------
    Private Sub OnImportScriptClick(sender As Object, e As EventArgs)
        Dim ofd As New OpenFileDialog() With {.Title = "Importeer Script (PDF/PDF-A)", .Filter = "PDF bestanden (*.pdf)|*.pdf", .Multiselect = False}
        If ofd.ShowDialog() <> DialogResult.OK Then Return
        Try
            Dim sb As New StringBuilder()
            Using pdf = PdfDocument.Open(ofd.FileName)
                Dim pageIndex As Integer = 1
                For Each page In pdf.GetPages()
                    Dim words = page.GetWords()
                    If words IsNot Nothing AndAlso words.Count > 0 Then
                        Dim lineBuilder As New StringBuilder()
                        Dim lastBottom As Double = -1
                        For Each w In words
                            Dim bottom = Math.Round(w.BoundingBox.Bottom, 1)
                            If lastBottom <> -1 AndAlso Math.Abs(bottom - lastBottom) > 1.5 Then
                                sb.AppendLine(lineBuilder.ToString().Trim())
                                lineBuilder.Clear()
                            End If
                            lineBuilder.Append(w.Text & " ")
                            lastBottom = bottom
                        Next
                        If lineBuilder.Length > 0 Then sb.AppendLine(lineBuilder.ToString().Trim())
                    Else
                        sb.AppendLine(page.Text)
                    End If
                    sb.AppendLine("--- Pagina " & pageIndex & " ---")
                    pageIndex += 1
                Next
            End Using
            Dim cleaned = PostProcessImportedText(sb.ToString())
            FrmMain.RichTextBox_ScriptEditor.Clear()
            FrmMain.RichTextBox_ScriptEditor.Text = cleaned
            LineTypes.Clear()
            BookmarkIds.Clear()
            CurrentDoc = Nothing
            ToonFlashBericht("Script geïmporteerd.", 2)
        Catch ex As Exception
            MessageBox.Show("Fout bij importeren PDF: " & ex.Message, "Fout", MessageBoxButtons.OK, MessageBoxIcon.Error)
        End Try
    End Sub

    Private Function PostProcessImportedText(raw As String) As String
        Return raw
    End Function

    Private Function ColorsEqual(a As Color, b As Color) As Boolean
        Return a.ToArgb() = b.ToArgb()
    End Function

    Private Function DetectLineTypeByFormatting(lineIndex As Integer, rtb As RichTextBox) As String
        ' Fast path: prefer stored type, avoid selecting/format reads
        If LineTypes.ContainsKey(lineIndex) Then Return LineTypes(lineIndex)
        Return "Comment"
    End Function

    ' Build display text for index based on type
    Private Function BuildDisplayForType(t As String, trimmed As String) As String
        Select Case t
            Case "H1" : Return trimmed
            Case "H2" : Return " " & trimmed
            Case "H3" : Return "   " & trimmed
            Case "SongTitle" : Return "   ♫ " & trimmed
            Case "Bookmark" : Return "   ⚑ " & trimmed
            Case Else : Return Nothing
        End Select
    End Function

    ' Helper: format across full line range while preserving selection
    Private Sub ApplyFormattingToLineRange(firstLine As Integer, lastLine As Integer, applyAction As Action)
        Dim rtb = FrmMain.RichTextBox_ScriptEditor
        If firstLine < 0 OrElse lastLine < firstLine Then Return
        Dim maxLine = rtb.Lines.Length - 1
        firstLine = Math.Max(0, firstLine)
        lastLine = Math.Min(maxLine, lastLine)
        Dim workStart = rtb.GetFirstCharIndexFromLine(firstLine)
        Dim lastStart = rtb.GetFirstCharIndexFromLine(lastLine)
        Dim workEnd = lastStart + rtb.Lines(lastLine).Length
        Dim workLen = Math.Max(0, workEnd - workStart)
        Dim selStart = rtb.SelectionStart
        Dim selLen = rtb.SelectionLength
        rtb.[Select](workStart, workLen)
        applyAction()
        rtb.SelectionStart = selStart
        rtb.SelectionLength = selLen
        rtb.Focus()
    End Sub

    ' Build a ScriptDocument snapshot from the current editor (fills StartPos/Length)
    Private Function BuildDocumentFromEditor() As ScriptDocument
        Dim rtb = FrmMain.RichTextBox_ScriptEditor
        Dim doc As New ScriptDocument With {.Lines = New List(Of ScriptLine)(), .StageHandActions = New List(Of StageHandAction)()}
        For i = 0 To rtb.Lines.Length - 1
            Dim startPos = rtb.GetFirstCharIndexFromLine(i)
            Dim txt = rtb.Lines(i)
            Dim len = txt.Length
            Dim t = If(LineTypes.ContainsKey(i) AndAlso Not String.IsNullOrEmpty(LineTypes(i)), LineTypes(i), "Comment")
            Dim bId As String = Nothing
            If t = "Bookmark" AndAlso BookmarkIds.ContainsKey(i) Then bId = BookmarkIds(i)
            doc.Lines.Add(New ScriptLine With {.Text = txt, .Type = t, .BookmarkId = bId, .StartPos = startPos, .Length = len})
        Next
        Return doc
    End Function

    ' New: fully (re)determine and apply layout based on ScriptLine info
    Private Sub RebuildLayoutFromScriptLines()
        Dim rtb = FrmMain.RichTextBox_ScriptEditor
        If CurrentDoc Is Nothing OrElse CurrentDoc.Lines Is Nothing Then Return

        ' Ensure doc lines align with current editor text; recompute positions
        Dim totalLines = rtb.Lines.Length
        If CurrentDoc.Lines.Count <> totalLines Then
            ' rebuild lines list to match editor, preserving types if available
            Dim newLines As New List(Of ScriptLine)
            For i = 0 To totalLines - 1
                Dim startPos = rtb.GetFirstCharIndexFromLine(i)
                Dim txt = rtb.Lines(i)
                Dim len = txt.Length
                Dim t As String = "Comment"
                If i < CurrentDoc.Lines.Count AndAlso Not String.IsNullOrEmpty(CurrentDoc.Lines(i).Type) Then
                    t = CurrentDoc.Lines(i).Type
                ElseIf LineTypes.ContainsKey(i) Then
                    t = LineTypes(i)
                End If
                Dim bId As String = Nothing
                If t = "Bookmark" AndAlso BookmarkIds.ContainsKey(i) Then bId = BookmarkIds(i)
                newLines.Add(New ScriptLine With {.Text = txt, .Type = t, .BookmarkId = bId, .StartPos = startPos, .Length = len})
            Next
            CurrentDoc.Lines = newLines
        Else
            For i = 0 To totalLines - 1
                Dim startPos = rtb.GetFirstCharIndexFromLine(i)
                CurrentDoc.Lines(i).StartPos = startPos
                CurrentDoc.Lines(i).Text = rtb.Lines(i)
                CurrentDoc.Lines(i).Length = rtb.Lines(i).Length
                If String.IsNullOrEmpty(CurrentDoc.Lines(i).Type) Then CurrentDoc.Lines(i).Type = "Comment"
            Next
        End If

        ' Sync LineTypes with document
        LineTypes.Clear()
        For i = 0 To CurrentDoc.Lines.Count - 1
            Dim tp = If(String.IsNullOrEmpty(CurrentDoc.Lines(i).Type), "Comment", CurrentDoc.Lines(i).Type)
            LineTypes(i) = tp
        Next

        ' Apply formatting for each line using StartPos/Length
        rtb.SuspendLayout()
        Try
            For i = 0 To CurrentDoc.Lines.Count - 1
                Dim line = CurrentDoc.Lines(i)
                If line.StartPos < 0 OrElse line.Length < 0 Then Continue For
                Dim safeLen = Math.Min(line.Length, Math.Max(0, rtb.TextLength - line.StartPos))
                If safeLen <= 0 Then Continue For
                rtb.[Select](line.StartPos, safeLen)
                ApplyFormattingForType(line.Type, False)
            Next
            rtb.[Select](rtb.TextLength, 0)
        Finally
            rtb.ResumeLayout()
        End Try
    End Sub

    ' --------------- SAVE / LOAD (no tags) ----------------
    Private Sub OnSaveScriptClick(sender As Object, e As EventArgs)
        Dim sfd As New SaveFileDialog() With {.Title = "Bewaar script", .Filter = "KLT Script (*.kls)|*.kls|Alle bestanden (*.*)|*.*", .DefaultExt = "kls"}
        If sfd.ShowDialog() <> DialogResult.OK Then Return
        Try
            CurrentDoc = BuildDocumentFromEditor()
            Dim json = JsonConvert.SerializeObject(CurrentDoc, Formatting.Indented)
            File.WriteAllText(sfd.FileName, json, Encoding.UTF8)
            ToonFlashBericht("Script opgeslagen (KLS).", 2)
        Catch ex As Exception
            MessageBox.Show("Fout bij opslaan: " & ex.Message)
        End Try
    End Sub

    Private Function SafeCellString(row As DataGridViewRow, name As String) As String
        If Not row.DataGridView.Columns.Contains(name) Then Return ""
        Dim v = row.Cells(name).Value
        If v Is Nothing Then Return ""
        Return v.ToString()
    End Function
    Private Function SafeCellInt(row As DataGridViewRow, name As String) As Integer
        Dim s = SafeCellString(row, name)
        Dim val As Integer = 0
        Integer.TryParse(s, val)
        Return val
    End Function

    Private Sub OnLoadScriptClick(sender As Object, e As EventArgs)
        Dim ofd As New OpenFileDialog() With {.Title = "Laad script", .Filter = "KLT Script (*.kls)|*.kls|Alle bestanden (*.*)|*.*", .Multiselect = False}
        If ofd.ShowDialog() <> DialogResult.OK Then Return
        Try
            Dim json = File.ReadAllText(ofd.FileName, Encoding.UTF8)
            Dim doc = JsonConvert.DeserializeObject(Of ScriptDocument)(json)
            If doc Is Nothing OrElse doc.Lines Is Nothing Then Throw New Exception("Ongeldig scriptbestand.")
            ' ensure default types and rebuild editor text
            For Each ln In doc.Lines
                If String.IsNullOrEmpty(ln.Type) Then ln.Type = "Comment"
            Next
            CurrentDoc = doc
            Dim sb As New StringBuilder()
            For i = 0 To CurrentDoc.Lines.Count - 1
                sb.AppendLine(CurrentDoc.Lines(i).Text)
            Next
            FrmMain.RichTextBox_ScriptEditor.Text = sb.ToString().TrimEnd()
            RebuildLayoutFromScriptLines()

            If FrmMain.DG_StageHandActions IsNot Nothing Then
                FrmMain.DG_StageHandActions.Rows.Clear()
                If CurrentDoc.StageHandActions IsNot Nothing Then
                    For Each act In CurrentDoc.StageHandActions.OrderBy(Function(a) a.BookmarkId).ThenBy(Function(a) a.OrderId)
                        FrmMain.DG_StageHandActions.Rows.Add(act.BookmarkId, act.OrderId, act.StageHand, act.WhenText, act.What)
                    Next
                End If
            End If
            ToonFlashBericht("Script geladen.", 2)
        Catch ex As Exception
            MessageBox.Show("Fout bij laden: " & ex.Message)
        End Try
    End Sub

    Private Sub ReapplyFormatting()
        ' Legacy formatting pass; prefer RebuildLayoutFromScriptLines
        RebuildLayoutFromScriptLines()
    End Sub

    Private Sub ApplyFormattingForType(t As String, rebuild As Boolean)
        Select Case If(String.IsNullOrEmpty(t), "Comment", t)
            Case "H1" : FormatHeader(1, False)
            Case "H2" : FormatHeader(2, False)
            Case "H3" : FormatHeader(3, False)
            Case "SongTitle" : FormatSongTitle(False)
            Case "SongText" : FormatSongText(True)
            Case "Comment" : FormatComment(False)
            Case "Acting" : FormatActing(False)
            Case "Actor" : FormatActor(True)
            Case "Bookmark" : FormatBookmark(False)
            Case Else : FormatComment(False)
        End Select
    End Sub

    ' ---------------- STYLE APPLICATION HELPERS ----------------
    Private Sub UpdateLinesTypeForSelection(typeValue As String)
        Dim rtb = FrmMain.RichTextBox_ScriptEditor
        Dim selStart = rtb.SelectionStart
        Dim selEnd = selStart + rtb.SelectionLength
        Dim firstLine = rtb.GetLineFromCharIndex(selStart)
        Dim lastLine = rtb.GetLineFromCharIndex(Math.Max(selEnd - 1, selStart))
        For ln = firstLine To lastLine
            LineTypes(ln) = typeValue
            If CurrentDoc IsNot Nothing AndAlso CurrentDoc.Lines IsNot Nothing AndAlso ln < CurrentDoc.Lines.Count Then
                CurrentDoc.Lines(ln).Type = typeValue
            End If
        Next
    End Sub

    ' new: update types based on an explicit line range (selection-safe)
    Private Sub UpdateLinesTypeForRange(firstLine As Integer, lastLine As Integer, typeValue As String)
        If firstLine < 0 OrElse lastLine < firstLine Then Return
        Dim maxLine = FrmMain.RichTextBox_ScriptEditor.Lines.Length - 1
        firstLine = Math.Max(0, firstLine)
        lastLine = Math.Min(maxLine, lastLine)
        For ln = firstLine To lastLine
            LineTypes(ln) = typeValue
            If CurrentDoc IsNot Nothing AndAlso CurrentDoc.Lines IsNot Nothing AndAlso ln < CurrentDoc.Lines.Count Then
                CurrentDoc.Lines(ln).Type = typeValue
            End If
        Next
    End Sub

    ' ---------------- APPLY ACTIONS ----------------
    Private Sub ApplyHeader(level As Integer)
        Dim rtb = FrmMain.RichTextBox_ScriptEditor
        If rtb Is Nothing Then Return
        rtb.SuspendLayout()
        Try
            If EnsureSelectionCoversLineIfEmpty(rtb) Then
                Dim selStart = rtb.SelectionStart
                Dim selLen = rtb.SelectionLength
                Dim firstLine = rtb.GetLineFromCharIndex(selStart)
                Dim lastLine = rtb.GetLineFromCharIndex(Math.Max(selStart + selLen - 1, selStart))
                ApplyFormattingToLineRange(firstLine, lastLine, Sub() FormatHeader(level, True))
                UpdateLinesTypeForRange(firstLine, lastLine, "H" & level)
            End If
        Catch ex As Exception
            ToonFlashBericht("Header formattering fout: " & ex.Message, 5, FlashSeverity.IsError)
        Finally
            rtb.ResumeLayout()
        End Try
    End Sub

