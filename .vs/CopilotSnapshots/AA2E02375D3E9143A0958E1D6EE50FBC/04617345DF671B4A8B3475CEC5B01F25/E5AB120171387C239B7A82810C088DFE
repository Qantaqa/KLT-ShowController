    ' Map van lineIndex -> Type (levend in de editor sessie)
    Private LineTypes As New Dictionary(Of Integer, String)

    Public Sub InitializeScriptEditor()
        If isInitialized Then Return
        If FrmMain IsNot Nothing Then
            For Each tsi In FrmMain.ToolStrip_ScriptEditor.Items
                Dim dd = TryCast(tsi, ToolStripDropDownButton)
                If dd IsNot Nothing Then
                    For Each mi As ToolStripItem In dd.DropDownItems
                        Select Case mi.Text.ToLowerInvariant()
                            Case "import" : AddHandler mi.Click, AddressOf OnImportScriptClick
                            Case "load" : AddHandler mi.Click, AddressOf OnLoadScriptClick
                            Case "save" : AddHandler mi.Click, AddressOf OnSaveScriptClick
                        End Select
                    Next
                End If
                Dim btn = TryCast(tsi, ToolStripButton)
                If btn IsNot Nothing Then
                    Select Case btn.Name
                        Case "TSB_Editor_H1" : AddHandler btn.Click, Sub() ApplyHeader(1)
                        Case "TSB_Editor_H2" : AddHandler btn.Click, Sub() ApplyHeader(2)
                        Case "TSB_Editor_H3" : AddHandler btn.Click, Sub() ApplyHeader(3)
                        Case "TSB_Editor_Comment" : AddHandler btn.Click, AddressOf ApplyComment
                        Case "TSB_Editor_SongText" : AddHandler btn.Click, AddressOf ApplySongText
                        Case "TSB_Editor_SongTitle" : AddHandler btn.Click, AddressOf ApplySongTitle
                        Case "TSB_Editor_Acting" : AddHandler btn.Click, AddressOf ApplyActing
                        Case "TSB_Editor_Actor" : AddHandler btn.Click, AddressOf ApplyActor
                        Case "TSB_Editor_RebuildIndex" : AddHandler btn.Click, Sub() BuildScriptIndex(FrmMain.RichTextBox_ScriptEditor.Text)
                        Case "TSB_Editor_Bookmark" : AddHandler btn.Click, AddressOf ApplyBookmark
                    End Select
                End If
            Next
            AddHandler FrmMain.ListBox_ScriptIndex.SelectedIndexChanged, AddressOf OnIndexSelected
        End If
        isInitialized = True
    End Sub

    ' ---------------- PDF IMPORT ----------------
    Private Sub OnImportScriptClick(sender As Object, e As EventArgs)
        Dim ofd As New OpenFileDialog() With {
            .Title = "Importeer Script (PDF/PDF-A)",
            .Filter = "PDF bestanden (*.pdf)|*.pdf",
            .Multiselect = False
        }
        If ofd.ShowDialog() <> DialogResult.OK Then Return
        Try
            Dim sb As New StringBuilder()
            Using pdf = PdfDocument.Open(ofd.FileName)
                Dim pageIndex As Integer = 1
                For Each page In pdf.GetPages()
                    Dim words = page.GetWords()
                    If words IsNot Nothing AndAlso words.Count > 0 Then
                        Dim lineBuilder As New StringBuilder()
                        Dim lastBottom As Double = -1
                        For Each w In words
                            Dim bottom = Math.Round(w.BoundingBox.Bottom, 1)
                            If lastBottom <> -1 AndAlso Math.Abs(bottom - lastBottom) > 1.5 Then
                                sb.AppendLine(lineBuilder.ToString().Trim())
                                lineBuilder.Clear()
                            End If
                            lineBuilder.Append(w.Text & " ")
                            lastBottom = bottom
                        Next
                        If lineBuilder.Length > 0 Then sb.AppendLine(lineBuilder.ToString().Trim())
                    Else
                        sb.AppendLine(page.Text)
                    End If
                    sb.AppendLine("--- Pagina " & pageIndex & " ---")
                    pageIndex += 1
                Next
            End Using
            Dim cleaned = PostProcessImportedText(sb.ToString())
            FrmMain.RichTextBox_ScriptEditor.Clear()
            FrmMain.RichTextBox_ScriptEditor.Text = cleaned
            LineTypes.Clear()
            BuildScriptIndex(cleaned)
            ToonFlashBericht("Script geïmporteerd.", 2)
        Catch ex As Exception
            MessageBox.Show("Fout bij importeren PDF: " & ex.Message, "Fout", MessageBoxButtons.OK, MessageBoxIcon.Error)
        End Try
    End Sub

    Private Function PostProcessImportedText(raw As String) As String
        Return raw
    End Function

    ' --------------- INDEX BUILD ----------------
    Private Sub BuildScriptIndex(allText As String)
        FrmMain.ListBox_ScriptIndex.Items.Clear()
        IndexEntries.Clear()

        Dim lines = allText.Split({Environment.NewLine}, StringSplitOptions.None)
        Dim scenePattern As New Regex("^\[SCENE\s+\d+\]", RegexOptions.IgnoreCase)
        Dim sceneAltPattern As New Regex("^(SCENE|SCÈNE)[ :]+\d+", RegexOptions.IgnoreCase)
        Dim songTitlePattern As New Regex("^NR\s+\d+[A-Z]?:\s+\"[^\"]+", RegexOptions.IgnoreCase)
        Dim timePattern As New Regex("\b\d{1,2}:\d{2}(:\d{2})?\b")

        Dim offset As Integer = 0
        For i = 0 To lines.Length - 1
            Dim line = lines(i)
            Dim trimmed = line.Trim()
            Dim kind As String = Nothing
            Dim display As String = Nothing
            Dim storedType As String = Nothing
            If LineTypes.ContainsKey(i) Then storedType = LineTypes(i)

            ' Determine classification priority by explicit stored types
            If storedType IsNot Nothing Then
                Select Case storedType
                    Case "H1", "H2", "H3"
                        kind = storedType
                        display = trimmed
                    Case "SongTitle"
                        kind = "SongTitle" : display = "♫ " & trimmed
                    Case "Bookmark"
                        kind = "Bookmark" : display = "⚑ " & trimmed
                    Case "Actor"
                        kind = "Actor" : display = "👤 " & trimmed
                    Case "SongText"
                        ' Songtekst niet in index tenzij wenselijk – overslaan
                    Case Else
                        ' Comment / Acting etc niet in index
                End Select
            End If

            ' Fallback pattern detection if no stored type
            If kind Is Nothing Then
                If scenePattern.IsMatch(trimmed) OrElse sceneAltPattern.IsMatch(trimmed) Then
                    kind = "H2"
                    display = trimmed
                ElseIf songTitlePattern.IsMatch(trimmed) Then
                    kind = "SongTitle"
                    display = "♫ " & trimmed
                ElseIf timePattern.IsMatch(trimmed) AndAlso trimmed.Length < 25 Then
                    kind = "Time"
                    display = trimmed
                End If
            End If

            If kind IsNot Nothing Then
                Dim entry As New IndexEntry With {.Display = display, .Offset = offset, .Kind = kind}
                IndexEntries.Add(entry)
                FrmMain.ListBox_ScriptIndex.Items.Add(display)
            End If
            offset += line.Length + Environment.NewLine.Length
        Next
    End Sub

    Private Sub OnIndexSelected(sender As Object, e As EventArgs)
        Dim lb = DirectCast(sender, ListBox)
        Dim idx = lb.SelectedIndex
        If idx < 0 OrElse idx >= IndexEntries.Count Then Return
        Dim entry = IndexEntries(idx)
        Dim rtb = FrmMain.RichTextBox_ScriptEditor
        If entry.Offset < 0 OrElse entry.Offset > rtb.TextLength Then Return
        rtb.SelectionStart = entry.Offset
        rtb.SelectionLength = 0
        rtb.ScrollToCaret()
        rtb.Focus()
    End Sub

    ' --------------- SAVE / LOAD ----------------
    Private Sub OnSaveScriptClick(sender As Object, e As EventArgs)
        Dim sfd As New SaveFileDialog() With {
            .Title = "Bewaar script",
            .Filter = "KLT Script (*.kls)|*.kls|Alle bestanden (*.*)|*.*",
            .DefaultExt = "kls"
        }
        If sfd.ShowDialog() <> DialogResult.OK Then Return
        Try
            Dim lines = FrmMain.RichTextBox_ScriptEditor.Text.Split({Environment.NewLine}, StringSplitOptions.None)
            Dim doc As New ScriptDocument With {.Lines = New List(Of ScriptLine)()}
            For i = 0 To lines.Length - 1
                Dim t As String = "Normal"
                If LineTypes.ContainsKey(i) Then t = LineTypes(i)
                doc.Lines.Add(New ScriptLine With {.Text = lines(i), .Type = t})
            Next
            Dim json = JsonConvert.SerializeObject(doc, Formatting.Indented)
            File.WriteAllText(sfd.FileName, json, Encoding.UTF8)
            ToonFlashBericht("Script opgeslagen (KLS).", 2)
        Catch ex As Exception
            MessageBox.Show("Fout bij opslaan: " & ex.Message)
        End Try
    End Sub

    Private Sub OnLoadScriptClick(sender As Object, e As EventArgs)
        Dim ofd As New OpenFileDialog() With {
            .Title = "Laad script",
            .Filter = "KLT Script (*.kls)|*.kls|Alle bestanden (*.*)|*.*",
            .Multiselect = False
        }
        If ofd.ShowDialog() <> DialogResult.OK Then Return
        Try
            Dim json = File.ReadAllText(ofd.FileName, Encoding.UTF8)
            Dim doc = JsonConvert.DeserializeObject(Of ScriptDocument)(json)
            If doc Is Nothing OrElse doc.Lines Is Nothing Then Throw New Exception("Ongeldig scriptbestand.")
            LineTypes.Clear()
            Dim sb As New StringBuilder()
            For i = 0 To doc.Lines.Count - 1
                sb.AppendLine(doc.Lines(i).Text)
                If Not String.IsNullOrEmpty(doc.Lines(i).Type) AndAlso doc.Lines(i).Type <> "Normal" Then
                    LineTypes(i) = doc.Lines(i).Type
                End If
            Next
            FrmMain.RichTextBox_ScriptEditor.Text = sb.ToString().TrimEnd() ' remove trailing newline from loop
            ' Reapply formatting based on types
            ReapplyFormatting()
            BuildScriptIndex(FrmMain.RichTextBox_ScriptEditor.Text)
            ToonFlashBericht("Script geladen.", 2)
        Catch ex As Exception
            MessageBox.Show("Fout bij laden: " & ex.Message)
        End Try
    End Sub

    Private Sub ReapplyFormatting()
        Dim rtb = FrmMain.RichTextBox_ScriptEditor
        rtb.SuspendLayout()
        Try
            For Each kv In LineTypes
                Dim idx = kv.Key
                If idx < 0 OrElse idx >= rtb.Lines.Length Then Continue For
                Dim lineStart = rtb.GetFirstCharIndexFromLine(idx)
                Dim lineText = rtb.Lines(idx)
                If lineStart < 0 Then Continue For
                rtb.Select(lineStart, lineText.Length)
                ApplyFormattingForType(kv.Value, False)
            Next
            rtb.Select(rtb.TextLength, 0)
        Finally
            rtb.ResumeLayout()
        End Try
    End Sub

    Private Sub ApplyFormattingForType(t As String, rebuild As Boolean)
        Select Case t
            Case "H1" : FormatHeader(1, False)
            Case "H2" : FormatHeader(2, False)
            Case "H3" : FormatHeader(3, False)
            Case "SongTitle" : FormatSongTitle(False)
            Case "SongText" : FormatSongText(False)
            Case "Comment" : FormatComment(False)
            Case "Acting" : FormatActing(False)
            Case "Actor" : FormatActor(False)
            Case "Bookmark" : FormatBookmark(False)
        End Select
        If rebuild Then BuildScriptIndex(FrmMain.RichTextBox_ScriptEditor.Text)
    End Sub

    ' ---------------- STYLE APPLICATION HELPERS ----------------
    Private Sub UpdateLinesTypeForSelection(typeValue As String)
        Dim rtb = FrmMain.RichTextBox_ScriptEditor
        Dim selStart = rtb.SelectionStart
        Dim selEnd = selStart + rtb.SelectionLength
        Dim firstLine = rtb.GetLineFromCharIndex(selStart)
        Dim lastLine = rtb.GetLineFromCharIndex(Math.Max(selEnd - 1, selStart))
        For ln = firstLine To lastLine
            LineTypes(ln) = typeValue
        Next
    End Sub

    Private Sub ApplyHeader(level As Integer)
        Dim rtb = FrmMain.RichTextBox_ScriptEditor
        If rtb Is Nothing Then Return
        rtb.SuspendLayout()
        Try
            EnsureSelectionCoversLineIfEmpty(rtb)
            FormatHeader(level, True)
            UpdateLinesTypeForSelection("H" & level)
        Catch ex As Exception
            ToonFlashBericht("Header formattering fout: " & ex.Message, 5, FlashSeverity.IsError)
        Finally
            rtb.ResumeLayout()
            BuildScriptIndex(rtb.Text)
        End Try
    End Sub

