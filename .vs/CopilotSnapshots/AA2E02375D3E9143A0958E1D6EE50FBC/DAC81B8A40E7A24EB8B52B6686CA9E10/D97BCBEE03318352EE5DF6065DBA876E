Imports System.Text.RegularExpressions

Module ScriptEditor
    ' Parse hulpfunctie
    Public Function TryParsePdfPageFromUrl(url As String, ByRef page As Integer) As Boolean
        If String.IsNullOrEmpty(url) Then Return False
        Dim m = System.Text.RegularExpressions.Regex.Match(url, "(?:[#&]|%23|%26)page=(\d+)", RegexOptions.IgnoreCase)
        If m.Success AndAlso Integer.TryParse(m.Groups(1).Value, page) Then Return True
        ' Fallback: plain #page=
        m = System.Text.RegularExpressions.Regex.Match(url, "page=(\d+)", RegexOptions.IgnoreCase)
        If m.Success AndAlso Integer.TryParse(m.Groups(1).Value, page) Then Return True
        Return False
    End Function

    Public Async Function GetCurrentPdfPageAsync() As Threading.Tasks.Task(Of Integer)
        Try
            If FrmMain Is Nothing OrElse FrmMain.pdfView Is Nothing OrElse FrmMain.pdfView.CoreWebView2 Is Nothing Then Return FrmMain.currentPdfPage
            ' Probeer URL (snel)
            Dim src As String = FrmMain.pdfView.CoreWebView2.Source
            Dim p As Integer
            If TryParsePdfPageFromUrl(src, p) Then
                Return p
            End If
            ' Fallback: vraag location.href via JS
            Dim res = Await FrmMain.pdfView.CoreWebView2.ExecuteScriptAsync("location.href")
            If Not String.IsNullOrEmpty(res) Then
                Dim href As String = res.Trim(""""c)
                If TryParsePdfPageFromUrl(href, p) Then
                    Return p
                End If
            End If
        Catch
        End Try
        Return FrmMain.currentPdfPage
    End Function

    Public Async Sub UpdateCurrentPdfPageFromWebView()
        FrmMain.currentPdfPage = Await GetCurrentPdfPageAsync()
    End Sub

    ' SourceChanged handler om page-mutaties te detecteren (bij scrollen/bediening in PDF-viewer)
    Public Sub OnPdfSourceChanged(sender As Object, e As Object)
        UpdateCurrentPdfPageFromWebView()
    End Sub

    ' Link huidige PDF-pagina aan geselecteerde DG_Show-regel
    Public Async Sub LinkSelectedRowToCurrentPage()
        If FrmMain.DG_Show Is Nothing OrElse FrmMain.DG_Show.CurrentRow Is Nothing Then
            ToonFlashBericht("Geen regel geselecteerd.", 3, FlashSeverity.IsInfo)
            Return
        End If
        Dim page = Await GetCurrentPdfPageAsync()
        FrmMain.DG_Show.CurrentRow.Cells("ScriptPg").Value = page
        ToonFlashBericht($"Script pagina {page} gelinkt aan deze regel.", 3)
    End Sub

    ' Ga naar gekoppelde pagina voor geselecteerde regel
    Public Sub NavigateToSelectedRowPage()
        If FrmMain.DG_Show Is Nothing OrElse FrmMain.DG_Show.CurrentRow Is Nothing Then
            ToonFlashBericht("Geen regel geselecteerd.", 3, FlashSeverity.IsInfo)
            Return
        End If
        Dim cell = FrmMain.DG_Show.CurrentRow.Cells("ScriptPg").Value
        Dim page As Integer
        If cell IsNot Nothing AndAlso Integer.TryParse(cell.ToString(), page) AndAlso page > 0 Then
            FrmMain.NavigatePdfToPage(page)
            ToonFlashBericht($"Naar script pagina {page}.", 2)
        Else
            ToonFlashBericht("Geen script pagina aan deze regel gekoppeld.", 4, FlashSeverity.IsInfo)
        End If
    End Sub

End Module
