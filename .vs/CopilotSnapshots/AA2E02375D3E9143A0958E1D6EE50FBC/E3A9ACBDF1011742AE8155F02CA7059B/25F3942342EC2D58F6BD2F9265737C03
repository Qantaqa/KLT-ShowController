    ' Jump to a given PDF page
    Private Sub NavigatePdfToPage(page As Integer)
        If String.IsNullOrEmpty(pdfFilePath) OrElse pdfView Is Nothing OrElse pdfView.CoreWebView2 Is Nothing Then Return
        Dim uri = New Uri(pdfFilePath).AbsoluteUri & "#page=" & Math.Max(1, page)
        pdfView.CoreWebView2.Navigate(uri)
    End Sub

    ' Auto-scroll tick: send PageDown to WebView2 to advance
    Private Sub OnPdfAutoScrollTick(sender As Object, e As EventArgs)
        If pdfView Is Nothing Then Return
        pdfView.Focus()
        SendKeys.SendWait("{PGDN}")
    End Sub

    Public Sub StartPdfAutoScroll(Optional intervalMs As Integer = -1)
        If intervalMs > 0 Then
            pdfAutoScrollIntervalMs = intervalMs
            If pdfAutoScrollTimer IsNot Nothing Then pdfAutoScrollTimer.Interval = intervalMs
        End If
        If pdfAutoScrollTimer IsNot Nothing Then pdfAutoScrollTimer.Start()
        ToonFlashBericht($"PDF autoscroll gestart ({If(intervalMs > 0, intervalMs, pdfAutoScrollIntervalMs)} ms).", 3)
    End Sub

    Public Sub StopPdfAutoScroll()
        If pdfAutoScrollTimer IsNot Nothing Then pdfAutoScrollTimer.Stop()
        ToonFlashBericht("PDF autoscroll gestopt.", 3)
    End Sub

    ' Keyboard shortcuts: F5 start, F6 stop, Ctrl + / - to adjust speed
    Private Sub FrmMain_KeyDown(sender As Object, e As KeyEventArgs) Handles Me.KeyDown
        If e.KeyCode = Keys.F5 Then
            StartPdfAutoScroll()
            e.Handled = True
        ElseIf e.KeyCode = Keys.F6 Then
            StopPdfAutoScroll()
            e.Handled = True
        ElseIf e.Control AndAlso (e.KeyCode = Keys.Oemplus OrElse e.KeyCode = Keys.Add) Then
            pdfAutoScrollIntervalMs = Math.Max(250, pdfAutoScrollIntervalMs - 250)
            pdfAutoScrollTimer.Interval = pdfAutoScrollIntervalMs
            ToonFlashBericht($"PDF scroll sneller: {pdfAutoScrollIntervalMs} ms", 2)
            e.Handled = True
        ElseIf e.Control AndAlso (e.KeyCode = Keys.OemMinus OrElse e.KeyCode = Keys.Subtract) Then
            pdfAutoScrollIntervalMs = Math.Min(20000, pdfAutoScrollIntervalMs + 250)
            pdfAutoScrollTimer.Interval = pdfAutoScrollIntervalMs
            ToonFlashBericht($"PDF scroll langzamer: {pdfAutoScrollIntervalMs} ms", 2)
            e.Handled = True
        End If
    End Sub

    ' Toon het PDF in SplitContainer2.Panel2
    Private Async Sub ShowPdfInPanel2()
        Try
            Dim configuredPath As String = settings_ScriptPDF.Text
            If String.IsNullOrWhiteSpace(configuredPath) Then Return

            Dim pdfFile As String = configuredPath
            If Directory.Exists(configuredPath) Then
                Dim firstPdf = Directory.EnumerateFiles(configuredPath, "*.pdf").OrderBy(Function(f) f).FirstOrDefault()
                If firstPdf Is Nothing Then
                    ToonFlashBericht("Geen PDF gevonden in map.", 5, FlashSeverity.IsInfo)
                    Return
                End If
                pdfFile = firstPdf
            ElseIf Not File.Exists(configuredPath) Then
                ToonFlashBericht("PDF bestand niet gevonden.", 5, FlashSeverity.IsWarning)
                Return
            End If

            pdfFilePath = pdfFile

            If pdfView Is Nothing Then
                pdfView = New WebView2() With {.Dock = DockStyle.Fill}
                SplitContainer2.Panel2.Controls.Clear()
                SplitContainer2.Panel2.Controls.Add(pdfView)
                Await pdfView.EnsureCoreWebView2Async(Nothing)
                AddHandler pdfView.CoreWebView2.NewWindowRequested, Sub(s, e)
                                                                        e.Handled = True
                                                                        pdfView.CoreWebView2.Navigate(e.Uri)
                                                                    End Sub
            ElseIf pdfView.CoreWebView2 Is Nothing Then
                Await pdfView.EnsureCoreWebView2Async(Nothing)
            End If

            Dim uri = New Uri(pdfFilePath).AbsoluteUri
            pdfView.CoreWebView2.Navigate(uri)
        Catch ex As Exception
            ToonFlashBericht("Kon PDF niet tonen: " & ex.Message, 10, FlashSeverity.IsError)
        End Try
    End Sub