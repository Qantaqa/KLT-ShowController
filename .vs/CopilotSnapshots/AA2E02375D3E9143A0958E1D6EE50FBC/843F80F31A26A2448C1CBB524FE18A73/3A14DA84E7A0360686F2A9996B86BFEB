    Private Sub ApplyBookmark(sender As Object, e As EventArgs)
        Dim rtb = FrmMain.RichTextBox_ScriptEditor : If rtb Is Nothing Then Return
        rtb.SuspendLayout()
        Try
            EnsureSelectionCoversLineIfEmpty(rtb)
            FormatBookmark(True)
            Dim selStart = rtb.SelectionStart
            Dim selEnd = selStart + rtb.SelectionLength
            Dim firstLine = rtb.GetLineFromCharIndex(selStart)
            Dim lastLine = rtb.GetLineFromCharIndex(Math.Max(selEnd - 1, selStart))
            For ln = firstLine To lastLine
                LineTypes(ln) = "Bookmark"
                If Not BookmarkIds.ContainsKey(ln) Then
                    Dim bid = $"BM{nextBookmarkCounter:0000}"
                    nextBookmarkCounter += 1
                    BookmarkIds(ln) = bid
                    If FrmMain.DG_StageHandActions IsNot Nothing Then
                        FrmMain.DG_StageHandActions.Rows.Add(BookmarkIds(ln), 1, "", "", "")
                    End If
                End If
            Next
            UpdateIndexForLineRange(firstLine, lastLine)
        Catch ex As Exception
            ToonFlashBericht("Bookmark fout: " & ex.Message, 5, FlashSeverity.IsError)
        Finally
            rtb.ResumeLayout()
        End Try
    End Sub

    ' ---------------- LOW LEVEL FORMATTERS ----------------
    Private Sub FormatHeader(level As Integer, modifyText As Boolean)
        Dim rtb = FrmMain.RichTextBox_ScriptEditor
        Dim baseSize = rtb.Font.Size
        Dim newSize As Single = baseSize
        Dim color As Color = Color.Black
        Select Case level
            Case 1 : newSize = baseSize + 6 : color = Color.DarkBlue
            Case 2 : newSize = baseSize + 4 : color = Color.SteelBlue
            Case 3 : newSize = baseSize + 2 : color = Color.SaddleBrown
        End Select
        rtb.SelectionColor = color
        rtb.SelectionFont = New Font(rtb.Font.FontFamily, newSize, FontStyle.Bold)
        If modifyText Then
            Dim selectedText = rtb.SelectedText
            Dim parts = selectedText.Split({Environment.NewLine}, StringSplitOptions.None)
            For i = 0 To parts.Length - 1
                parts(i) = parts(i).Trim()
            Next
            rtb.SelectedText = String.Join(Environment.NewLine, parts)
        End If
    End Sub

    Private Sub FormatComment(modifyText As Boolean)
