    Public Sub InitializeScriptEditor()
        If isInitialized Then Return
        If FrmMain IsNot Nothing Then
            For Each tsi In FrmMain.ToolStrip_ScriptEditor.Items
                Dim dd = TryCast(tsi, ToolStripDropDownButton)
                If dd IsNot Nothing Then
                    For Each mi As ToolStripItem In dd.DropDownItems
                        Select Case mi.Text.ToLowerInvariant()
                            Case "import" : AddHandler mi.Click, AddressOf OnImportScriptClick
                            Case "load" : AddHandler mi.Click, AddressOf OnLoadScriptClick
                            Case "save" : AddHandler mi.Click, AddressOf OnSaveScriptClick
                        End Select
                    Next
                End If
                Dim btn = TryCast(tsi, ToolStripButton)
                If btn IsNot Nothing Then
                    Select Case btn.Name
                        Case "TSB_Editor_H1" : AddHandler btn.Click, Sub() ApplyHeader(1)
                        Case "TSB_Editor_H2" : AddHandler btn.Click, Sub() ApplyHeader(2)
                        Case "TSB_Editor_H3" : AddHandler btn.Click, Sub() ApplyHeader(3)
                        Case "TSB_Editor_Comment" : AddHandler btn.Click, AddressOf ApplyComment
                        Case "TSB_Editor_SongText" : AddHandler btn.Click, AddressOf ApplySongText
                        Case "TSB_Editor_SongTitle" : AddHandler btn.Click, AddressOf ApplySongTitle
                        Case "TSB_Editor_Acting" : AddHandler btn.Click, AddressOf ApplyActing
                        Case "TSB_Editor_Actor" : AddHandler btn.Click, AddressOf ApplyActor
                        Case "TSB_Editor_RebuildIndex" : AddHandler btn.Click, Sub() BuildScriptIndex(FrmMain.RichTextBox_ScriptEditor.Text)
                        Case "TSB_Editor_Bookmark" : AddHandler btn.Click, AddressOf ApplyBookmark
                    End Select
                End If
            Next
            AddHandler FrmMain.ListBox_ScriptIndex.SelectedIndexChanged, AddressOf OnIndexSelected
            ' Keep metadata in sync when user deletes / merges lines
            AddHandler FrmMain.RichTextBox_ScriptEditor.TextChanged, AddressOf OnScriptTextChanged
        End If
        isInitialized = True
    End Sub

    Private Sub OnScriptTextChanged(sender As Object, e As EventArgs)
        SyncMetaWithCurrentLines()
    End Sub

    Private Sub SyncMetaWithCurrentLines()
        Dim lines = SplitIntoLines(FrmMain.RichTextBox_ScriptEditor.Text)
        ' Remove metadata for lines that no longer exist
        Dim keysToRemove = LineTypes.Keys.Where(Function(k) k >= lines.Length).ToList()
        For Each k In keysToRemove
            LineTypes.Remove(k)
        Next
        keysToRemove = BookmarkIds.Keys.Where(Function(k) k >= lines.Length).ToList()
        For Each k In keysToRemove
            BookmarkIds.Remove(k)
        Next
        ' (Optional advanced remapping could be added here, but for now we keep surviving indices only)
    End Sub

    Private Function SplitIntoLines(text As String) As String()
        If String.IsNullOrEmpty(text) Then Return Array.Empty(Of String)()
        Dim normalized = text.Replace(vbCrLf, vbLf).Replace(vbCr, vbLf)
        Dim parts = normalized.Split(New Char() {ControlChars.Lf}, StringSplitOptions.None)
        Return parts
    End Function

    ' ---------------- PDF IMPORT ----------------
    Private Sub OnImportScriptClick(sender As Object, e As EventArgs)
        Dim ofd As New OpenFileDialog() With {.Title = "Importeer Script (PDF/PDF-A)", .Filter = "PDF bestanden (*.pdf)|*.pdf", .Multiselect = False}
        If ofd.ShowDialog() <> DialogResult.OK Then Return
        Try
            Dim sb As New StringBuilder()
            Using pdf = PdfDocument.Open(ofd.FileName)
                Dim pageIndex As Integer = 1
                For Each page In pdf.GetPages()
                    Dim words = page.GetWords()
                    If words IsNot Nothing AndAlso words.Count > 0 Then
                        Dim lineBuilder As New StringBuilder()
                        Dim lastBottom As Double = -1
                        For Each w In words
                            Dim bottom = Math.Round(w.BoundingBox.Bottom, 1)
                            If lastBottom <> -1 AndAlso Math.Abs(bottom - lastBottom) > 1.5 Then
                                sb.AppendLine(lineBuilder.ToString().Trim())
                                lineBuilder.Clear()
                            End If
                            lineBuilder.Append(w.Text & " ")
                            lastBottom = bottom
                        Next
                        If lineBuilder.Length > 0 Then sb.AppendLine(lineBuilder.ToString().Trim())
                    Else
                        sb.AppendLine(page.Text)
                    End If
                    sb.AppendLine("--- Pagina " & pageIndex & " ---")
                    pageIndex += 1
                Next
            End Using
            Dim cleaned = PostProcessImportedText(sb.ToString())
            FrmMain.RichTextBox_ScriptEditor.Clear()
            FrmMain.RichTextBox_ScriptEditor.Text = cleaned
            LineTypes.Clear()
            BookmarkIds.Clear()
            BuildScriptIndex(cleaned)
            ToonFlashBericht("Script geïmporteerd.", 2)
        Catch ex As Exception
            MessageBox.Show("Fout bij importeren PDF: " & ex.Message, "Fout", MessageBoxButtons.OK, MessageBoxIcon.Error)
        End Try
    End Sub

    Private Function PostProcessImportedText(raw As String) As String
        Return raw
    End Function

    ' ---------- FORMAT DETECTION (avoid stale indices) ----------
    Private Function ColorsEqual(a As Color, b As Color) As Boolean
        Return a.ToArgb() = b.ToArgb()
    End Function

    Private Function DetectLineTypeByFormatting(lineIndex As Integer, rtb As RichTextBox) As String
        If lineIndex < 0 OrElse lineIndex >= rtb.Lines.Length Then Return "Normal"
        Dim lineStart = rtb.GetFirstCharIndexFromLine(lineIndex)
        If lineStart < 0 Then Return "Normal"
        Dim lineText = rtb.Lines(lineIndex)
        If String.IsNullOrWhiteSpace(lineText) Then Return "Normal"

        Dim origStart = rtb.SelectionStart
        Dim origLen = rtb.SelectionLength
        Try
            ' move to first non-whitespace char within this line
            Dim pos = lineStart
            Dim endOfLine = lineStart + lineText.Length
            While pos < endOfLine AndAlso Char.IsWhiteSpace(rtb.Text(pos))
                pos += 1
            End While
            If pos >= endOfLine Then Return "Normal"
            rtb.[Select](pos, 1)
            Dim c = rtb.SelectionColor
            Dim f = rtb.SelectionFont
            Dim indent = rtb.SelectionIndent
            Dim isBold = (f IsNot Nothing AndAlso f.Bold)
            Dim isItalic = (f IsNot Nothing AndAlso f.Italic)

            If ColorsEqual(c, Color.DarkBlue) AndAlso isBold Then Return "H1"
            If ColorsEqual(c, Color.SteelBlue) AndAlso isBold Then Return "H2"
            If ColorsEqual(c, Color.SaddleBrown) AndAlso isBold Then Return "H3"
            If ColorsEqual(c, Color.Red) AndAlso isBold Then Return "SongTitle"
            If ColorsEqual(c, Color.Orange) AndAlso isBold Then Return "SongText"
            If ColorsEqual(c, Color.DarkViolet) AndAlso isBold Then Return "Bookmark"
            If ColorsEqual(c, Color.LightBlue) AndAlso isBold Then Return "Actor"
            If ColorsEqual(c, Color.Gray) AndAlso isItalic Then Return "Comment"
            If ColorsEqual(c, Color.White) AndAlso indent >= 30 Then Return "Acting"

            Return "Normal"
        Finally
            rtb.[Select](origStart, origLen)
        End Try
    End Function

    ' Build display text for index based on type
    Private Function BuildDisplayForType(t As String, trimmed As String) As String
        Select Case t
            Case "H1" : Return trimmed
            Case "H2" : Return " " & trimmed
            Case "H3" : Return "   " & trimmed
            Case "SongTitle" : Return "   ♫ " & trimmed
            Case "Bookmark" : Return "   ⚑ " & trimmed
            Case Else : Return Nothing
        End Select
    End Function

    ' Incremental index update for a given line range
    Private Sub UpdateIndexForLineRange(firstLine As Integer, lastLine As Integer)
        Dim rtb = FrmMain.RichTextBox_ScriptEditor
        If rtb Is Nothing Then Return
        If rtb.Lines.Length = 0 Then
            FrmMain.ListBox_ScriptIndex.Items.Clear()
            IndexEntries.Clear()
            Return
        End If
        If firstLine > lastLine Then Return
        firstLine = Math.Max(0, firstLine)
        lastLine = Math.Min(rtb.Lines.Length - 1, lastLine)
        If lastLine < 0 Then Return

        ' remove old entries in range (from end)
        Dim removeIdx As New List(Of Integer)
        For i = 0 To IndexEntries.Count - 1
            Dim en = IndexEntries(i)
            If en.LineIndex >= firstLine AndAlso en.LineIndex <= lastLine Then removeIdx.Add(i)
        Next
        removeIdx.Reverse()
        For Each idx In removeIdx
            IndexEntries.RemoveAt(idx)
            FrmMain.ListBox_ScriptIndex.Items.RemoveAt(idx)
        Next

        ' add updated entries for range, keeping by line index order
        For ln = firstLine To lastLine
            Dim t As String = If(LineTypes.ContainsKey(ln), LineTypes(ln), DetectLineTypeByFormatting(ln, rtb))
            If String.IsNullOrEmpty(t) OrElse t = "Normal" Then Continue For
            Dim trimmed = rtb.Lines(ln).Trim()
            Dim display = BuildDisplayForType(t, trimmed)
            If String.IsNullOrEmpty(display) Then Continue For
            Dim offset = rtb.GetFirstCharIndexFromLine(ln)
            Dim entry As New IndexEntry With {.Display = display, .Offset = offset, .Kind = t, .LineIndex = ln}
            Dim insertPos = IndexEntries.FindIndex(Function(e) e.LineIndex > ln)
            If insertPos < 0 Then insertPos = IndexEntries.Count
            IndexEntries.Insert(insertPos, entry)
            FrmMain.ListBox_ScriptIndex.Items.Insert(insertPos, display)
        Next
    End Sub

    ' --------------- INDEX BUILD ----------------
    Private Sub BuildScriptIndex(allText As String)
        Dim rtb = FrmMain.RichTextBox_ScriptEditor
        FrmMain.ListBox_ScriptIndex.Items.Clear()
        IndexEntries.Clear()

        LineTypes.Clear()
        For i = 0 To rtb.Lines.Length - 1
            Dim t = DetectLineTypeByFormatting(i, rtb)
            If t <> "Normal" Then LineTypes(i) = t
        Next

        For i = 0 To rtb.Lines.Length - 1
            If Not LineTypes.ContainsKey(i) Then Continue For
            Dim t = LineTypes(i)
            Dim trimmed = rtb.Lines(i).Trim()
            Dim display = BuildDisplayForType(t, trimmed)
            If String.IsNullOrEmpty(display) Then Continue For
            Dim offset = rtb.GetFirstCharIndexFromLine(i)
            Dim entry As New IndexEntry With {.Display = display, .Offset = offset, .Kind = t, .LineIndex = i}
            IndexEntries.Add(entry)
            FrmMain.ListBox_ScriptIndex.Items.Add(display)
        Next
    End Sub

    Private Sub OnIndexSelected(sender As Object, e As EventArgs)
        Dim lb = DirectCast(sender, ListBox)
        Dim idx = lb.SelectedIndex
        If idx < 0 OrElse idx >= IndexEntries.Count Then Return
        Dim entry = IndexEntries(idx)
        Dim rtb = FrmMain.RichTextBox_ScriptEditor
        If entry.Offset < 0 OrElse entry.Offset > rtb.TextLength Then Return
        rtb.SelectionStart = entry.Offset
        rtb.SelectionLength = 0
        rtb.ScrollToCaret()
        rtb.Focus()
    End Sub

    ' --------------- SAVE / LOAD (no tags) ----------------
    Private Sub OnSaveScriptClick(sender As Object, e As EventArgs)
        Dim sfd As New SaveFileDialog() With {.Title = "Bewaar script", .Filter = "KLT Script (*.kls)|*.kls|Alle bestanden (*.*)|*.*", .DefaultExt = "kls"}
        If sfd.ShowDialog() <> DialogResult.OK Then Return
        Try
            Dim rtb = FrmMain.RichTextBox_ScriptEditor
            Dim doc As New ScriptDocument With {.Lines = New List(Of ScriptLine)(), .StageHandActions = New List(Of StageHandAction)()}
            For i = 0 To rtb.Lines.Length - 1
                Dim t = DetectLineTypeByFormatting(i, rtb)
                Dim raw = rtb.Lines(i)
                Dim bId As String = Nothing
                If t = "Bookmark" AndAlso BookmarkIds.ContainsKey(i) Then bId = BookmarkIds(i)
                doc.Lines.Add(New ScriptLine With {.Text = raw, .Type = t, .BookmarkId = bId})
            Next
            If FrmMain.DG_StageHandActions IsNot Nothing Then
                For Each row As DataGridViewRow In FrmMain.DG_StageHandActions.Rows
                    If row.IsNewRow Then Continue For
                    Dim bid = SafeCellString(row, "col_SH_BookMarkID")
                    Dim ord = SafeCellInt(row, "col_SH_OrderId")
                    Dim sh = SafeCellString(row, "col_SH_StageHand")
                    Dim whn = SafeCellString(row, "col_SH_When")
                    Dim wht = SafeCellString(row, "col_SH_What")
                    If bid <> "" OrElse sh <> "" OrElse wht <> "" Then
                        doc.StageHandActions.Add(New StageHandAction With {.BookmarkId = bid, .OrderId = ord, .StageHand = sh, .WhenText = whn, .What = wht})
                    End If
                Next
            End If
            Dim json = JsonConvert.SerializeObject(doc, Formatting.Indented)
            File.WriteAllText(sfd.FileName, json, Encoding.UTF8)
            ToonFlashBericht("Script opgeslagen (KLS).", 2)
        Catch ex As Exception
            MessageBox.Show("Fout bij opslaan: " & ex.Message)
        End Try
    End Sub

    Private Function SafeCellString(row As DataGridViewRow, name As String) As String
        If Not row.DataGridView.Columns.Contains(name) Then Return ""
        Dim v = row.Cells(name).Value
        If v Is Nothing Then Return ""
        Return v.ToString()
    End Function
    Private Function SafeCellInt(row As DataGridViewRow, name As String) As Integer
        Dim s = SafeCellString(row, name)
        Dim val As Integer = 0
        Integer.TryParse(s, val)
        Return val
    End Function

    Private Sub OnLoadScriptClick(sender As Object, e As EventArgs)
        Dim ofd As New OpenFileDialog() With {.Title = "Laad script", .Filter = "KLT Script (*.kls)|*.kls|Alle bestanden (*.*)|*.*", .Multiselect = False}
        If ofd.ShowDialog() <> DialogResult.OK Then Return
        Try
            Dim json = File.ReadAllText(ofd.FileName, Encoding.UTF8)
            Dim doc = JsonConvert.DeserializeObject(Of ScriptDocument)(json)
            If doc Is Nothing OrElse doc.Lines Is Nothing Then Throw New Exception("Ongeldig scriptbestand.")
            LineTypes.Clear()
            BookmarkIds.Clear()
            Dim sb As New StringBuilder()
            For i = 0 To doc.Lines.Count - 1
                Dim ln = doc.Lines(i)
                sb.AppendLine(ln.Text)
                If ln.Type IsNot Nothing AndAlso ln.Type <> "Normal" Then LineTypes(i) = ln.Type
                If ln.Type = "Bookmark" AndAlso Not String.IsNullOrEmpty(ln.BookmarkId) Then BookmarkIds(i) = ln.BookmarkId
            Next
            FrmMain.RichTextBox_ScriptEditor.Text = sb.ToString().TrimEnd()
            ReapplyFormatting()
            BuildScriptIndex(FrmMain.RichTextBox_ScriptEditor.Text)
            If FrmMain.DG_StageHandActions IsNot Nothing Then
                FrmMain.DG_StageHandActions.Rows.Clear()
                If doc.StageHandActions IsNot Nothing Then
                    For Each act In doc.StageHandActions.OrderBy(Function(a) a.BookmarkId).ThenBy(Function(a) a.OrderId)
                        FrmMain.DG_StageHandActions.Rows.Add(act.BookmarkId, act.OrderId, act.StageHand, act.WhenText, act.What)
                    Next
                End If
            End If
            ToonFlashBericht("Script geladen.", 2)
        Catch ex As Exception
            MessageBox.Show("Fout bij laden: " & ex.Message)
        End Try
    End Sub

    Private Sub ReapplyFormatting()
        Dim rtb = FrmMain.RichTextBox_ScriptEditor
        rtb.SuspendLayout()
        Try
            For lineIndex = 0 To rtb.Lines.Length - 1
                Dim t As String = Nothing
                If LineTypes.ContainsKey(lineIndex) Then t = LineTypes(lineIndex)
                If String.IsNullOrEmpty(t) OrElse t = "Normal" Then Continue For
                Dim lineStart = rtb.GetFirstCharIndexFromLine(lineIndex)
                If lineStart < 0 Then Continue For
                Dim lineText = rtb.Lines(lineIndex)
                rtb.[Select](lineStart, lineText.Length)
                ApplyFormattingForType(t, False)
            Next
            rtb.[Select](rtb.TextLength, 0)
        Finally
            rtb.ResumeLayout()
        End Try
    End Sub

    Private Sub ApplyFormattingForType(t As String, rebuild As Boolean)
        Select Case t
            Case "H1" : FormatHeader(1, False)
            Case "H2" : FormatHeader(2, False)
            Case "H3" : FormatHeader(3, False)
            Case "SongTitle" : FormatSongTitle(False)
            Case "SongText" : FormatSongText(False)
            Case "Comment" : FormatComment(False)
            Case "Acting" : FormatActing(False)
            Case "Actor" : FormatActor(False)
            Case "Bookmark" : FormatBookmark(False)
        End Select
        'If rebuild Then BuildScriptIndex(FrmMain.RichTextBox_ScriptEditor.Text)
    End Sub

    ' ---------------- STYLE APPLICATION HELPERS ----------------
    Private Sub UpdateLinesTypeForSelection(typeValue As String)
        Dim rtb = FrmMain.RichTextBox_ScriptEditor
        Dim selStart = rtb.SelectionStart
        Dim selEnd = selStart + rtb.SelectionLength
        Dim firstLine = rtb.GetLineFromCharIndex(selStart)
        Dim lastLine = rtb.GetLineFromCharIndex(Math.Max(selEnd - 1, selStart))
        For ln = firstLine To lastLine
            LineTypes(ln) = typeValue
        Next
        ' Incremental index update just for affected lines
        UpdateIndexForLineRange(firstLine, lastLine)
    End Sub

