    Private Sub EnsureSelectionCoversLineIfEmpty(rtb As RichTextBox)
        If rtb.SelectionLength > 0 Then Return
        Dim selStart = rtb.SelectionStart
        Dim lineIndex = rtb.GetLineFromCharIndex(selStart)
        If lineIndex < 0 OrElse lineIndex >= rtb.Lines.Length Then Return
        Dim lineStart = rtb.GetFirstCharIndexFromLine(lineIndex)
        Dim lineText = rtb.Lines(lineIndex)
        rtb.SelectionStart = lineStart
        rtb.SelectionLength = lineText.Length
    End Sub

